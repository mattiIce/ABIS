# PowerBuilder compiled libraries are binary: don't attempt text diff/merge,
# and keep them out of language statistics.
*.pbl   binary linguist-generated
*.pbd   binary

# PowerBuilder runtime DLLs and binary option files: binary, and vendored so
# they don't skew language statistics.
*.dll   binary linguist-vendored
*.DLL   binary linguist-vendored
*.opt   binary

# PowerBuilder exported sources are text. Keep them LF-normalized in the repo
# so diffs are stable across platforms.
*.srd   text
*.srq   text
*.src   text
*.sra   text
*.srw   text
*.sru   text
*.srf   text
*.srs   text
*.srm   text
*.pbw   text
*.pbt   text

# Generated analysis artifacts.
docs/**/*.json  text

# Shell scripts must stay LF even on Windows checkouts (autocrlf=true) — they run
# on the Ubuntu install/build host, where CRLF would break the shebang/parsing.
*.sh    text eol=lf

# Other Linux deploy assets that must stay LF: the systemd unit, the sourced
# answers file, the nginx site templates, the .deb maintainer scripts, and the
# extensionless abis-configure helper (CRLF would corrupt parsing / a #! line on
# the target host).
deploy/abis.service        text eol=lf
deploy/*.answers.example    text eol=lf
deploy/nginx/*.conf         text eol=lf
deploy/abis-configure       text eol=lf
deploy/debian/postinst      text eol=lf
deploy/debian/prerm         text eol=lf
deploy/debian/postrm        text eol=lf
deploy/debian/control       text eol=lf
