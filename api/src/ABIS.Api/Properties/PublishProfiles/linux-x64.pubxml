<?xml version="1.0" encoding="utf-8"?>
<!--
  Self-contained linux-x64 publish for the native systemd install (Path A in
  docs/INSTALL_PLAN.md). Bundles the .NET runtime so the target Ubuntu server
  needs nothing pre-installed. Oracle.ManagedDataAccess.Core is fully managed,
  so there are no native dependencies to ship.

  Used by build-release.sh:
    dotnet publish src/ABIS.Api -c Release \
      /p:PublishProfile=linux-x64 /p:Version=<version> -o <out>

  Not single-file/trimmed on purpose: the tarball bundles the folder anyway, and
  a plain framework-folder layout avoids single-file extraction + trimming
  surprises with the reflection-heavy Oracle/Dapper paths.
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishProtocol>FileSystem</PublishProtocol>
    <RuntimeIdentifier>linux-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishTrimmed>false</PublishTrimmed>
    <PublishReadyToRun>false</PublishReadyToRun>
  </PropertyGroup>
</Project>
