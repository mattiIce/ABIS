{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Database": {
    "Provider": "Sqlite",
    "ConnectionString": "Data Source=abis_dev.db",
    "Seed": true
  },
  "ApiKeys": {
    "Enabled": true,
    "HeaderName": "X-Api-Key",
    "Keys": [ "dev-local-key" ]
  }
}
