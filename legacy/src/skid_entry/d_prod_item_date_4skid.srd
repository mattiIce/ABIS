column(band=detail id=2 alignment="0" tabsequence=32766 border="0" color="33554432" x="562" y="0" height="56" width="992" format="[general]" html.valueishtml="0"  name=prod_item_num visible="1" edit.limit=0 edit.case=any edit.focusrectangle=no edit.autoselect=no edit.imemode=0  font.face="Arial" font.height="-8" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="536870912" )
