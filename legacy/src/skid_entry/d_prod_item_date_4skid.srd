detail(height=76 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=prod_item_date dbname="production_sheet_item.prod_item_date" )
 column=(type=decimal(0) updatewhereclause=yes name=prod_item_num dbname="production_sheet_item.prod_item_num" )
 retrieve="select 	production_sheet_item.prod_item_date,
			production_sheet_item.prod_item_num
from     production_sheet_item 
         join sheet_skid_detail on production_sheet_item.prod_item_num = sheet_skid_detail.prod_item_num
         join sheet_skid on sheet_skid.sheet_skid_num = sheet_skid_detail.sheet_skid_num
         join ab_job on ab_job.ab_job_num = production_sheet_item.ab_job_num and sheet_skid.ab_job_num = ab_job.ab_job_num
where    production_sheet_item.ab_job_num = :al_ab_job_num
and      sheet_skid.sheet_skid_num = :al_sheet_skid_num" arguments=(("al_ab_job_num", number),("al_sheet_skid_num", number)) )
text(band=header alignment="0" text="Prod Item Date" border="0" color="33554432" x="0" y="4" height="56" width="562" html.valueishtml="0"  name=prod_item_date_t visible="1"  font.face="Arial" font.height="-8" font.weight="700"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="536870912" )
