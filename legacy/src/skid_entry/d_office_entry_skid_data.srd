 column=(type=char(18) update=yes updatewhereclause=yes name=skid_location dbname="sheet_skid.skid_location" )
 column=(type=datetime update=yes updatewhereclause=yes name=skid_date dbname="sheet_skid.skid_date" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=skid_sheet_status dbname="sheet_skid.skid_sheet_status" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=skid_pieces dbname="sheet_skid.skid_pieces" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=sheet_theoretical_wt dbname="sheet_skid.sheet_theoretical_wt" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"sheet_skid~" ) COLUMN(NAME=~"sheet_skid.sheet_skid_num~") COLUMN(NAME=~"sheet_skid.ab_job_num~") COLUMN(NAME=~"sheet_skid.sheet_net_wt~") COLUMN(NAME=~"sheet_skid.sheet_tare_wt~") COLUMN(NAME=~"sheet_skid.skid_edi856_date~") COLUMN(NAME=~"sheet_skid.skid_location~") COLUMN(NAME=~"sheet_skid.skid_date~") COLUMN(NAME=~"sheet_skid.skid_sheet_status~") COLUMN(NAME=~"sheet_skid.skid_pieces~") COLUMN(NAME=~"sheet_skid.sheet_theoretical_wt~")WHERE(    EXP1 =~" ~~~"SHEET_SKID~~~".~~~"AB_JOB_NUM~~~"~"   OP =~"=~"    EXP2 =~":al_job_num ~"    LOGIC =~"or~" ) WHERE(    EXP1 =~"~~~"SHEET_SKID~~~".~~~"SKID_SHEET_STATUS~~~"~"   OP =~"=~"    EXP2 =~"7~" ) ) ARG(NAME = ~"al_job_num~" TYPE = number) " update="SHEET_SKID" updatewhere=2 updatekeyinplace=yes arguments=(("al_job_num", number)) )
