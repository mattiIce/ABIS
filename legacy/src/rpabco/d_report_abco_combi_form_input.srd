 column=(type=char(0) updatewhereclause=yes name=cust_order dbname="shipment.cust_order" )
 retrieve="  SELECT ~"SHIPMENT~".~"PACKING_LIST~",   
         ~"SHIPMENT~".~"BILL_OF_LADING~",   
         ~"SHIPMENT~".~"DES_SH_CUST_ID~",   
         ~"SHIPMENT~".~"CUSTOMER_ID~",   
         ~"SHIPMENT~".~"SHIPMENT_ACTUALED_DATE_TIME~",   
         ~"SHIPMENT~".~"VEHICLE_ID~",
			NULL ~"deliver_t~",
			NULL ~"package_t~",
			NULL ~"ref1_t~",
			NULL ~"ref2_t~",
			NULL ~"note1_t~",
			NULL ~"note2_t~",
			NULL ~"note3_t~",
			NULL ~"cust_order~"
    FROM ~"SHIPMENT~"  
   WHERE ~"SHIPMENT~".~"PACKING_LIST~" = :al_packing_list    
" arguments=(("al_packing_list", number)) )
