 column=(type=char(1) updatewhereclause=yes name=trimmed_width_overridden dbname="trimmed_width_overridden" )
 column=(type=number updatewhereclause=yes name=dimpling_code dbname="dimpling_code" )
 column=(type=char(1) updatewhereclause=yes name=special_part dbname="special_part" )
 column=(type=char(32) updatewhereclause=yes name=die_name dbname="die_name" )
 column=(type=char(255) updatewhereclause=yes name=line_desc dbname="line_desc" )
 column=(type=decimal(0) updatewhereclause=yes name=spm dbname="spm" )
 column=(type=decimal(0) updatewhereclause=yes name=efficiency_percent dbname="efficiency_percent" )
 column=(type=decimal(0) updatewhereclause=yes name=pieces_skid dbname="pieces_skid" )
 retrieve="  SELECT ~"PART_NUM~".~"PART_NUM_ID~",   
         ~"PART_NUM~".~"ENDUSER_PART_NUM~",   
         ~"PART_NUM~".~"CUSTOMER_ID~",   
         ~"PART_NUM~".~"ENDUSER_ID~",   
         ~"PART_NUM~".~"SHEET_TYPE~",   
         ~"PART_NUM~".~"ALLOY~",   
         ~"PART_NUM~".~"TEMPER~",   
         ~"PART_NUM~".~"GAUGE~",   
         ~"PART_NUM~".~"GAUGE_P~",   
         ~"PART_NUM~".~"GAUGE_M~",   
         ~"PART_NUM~".~"PACKAGING_SPEC1~",   
         ~"PART_NUM~".~"PACKAGING_SPEC2~",   
         ~"PART_NUM~".~"PACKAGING_SPEC3~",   
         ~"PART_NUM~".~"PACKAGING_SPEC4~",   
         ~"PART_NUM~".~"PACKAGING_SPEC5~",   
         ~"PART_NUM~".~"PACKAGING_SPEC6~",   
         ~"PART_NUM~".~"PACKAGING_SPEC7~",   
         ~"PART_NUM~".~"PACKAGING_BANDS~",   
         ~"PART_NUM~".~"PACKAGING_OTHER_SPEC~",   
         ~"PART_NUM~".~"ITEM_STATUS~",   
         ~"PART_NUM~".~"ITEM_DESC~",   
         ~"PART_NUM~".~"ITEM_NOTE~",   
         ~"PART_NUM~".~"MATERIAL_END_USE~",   
         ~"PART_NUM~".~"SURFACE~",   
         ~"PART_NUM~".~"FLATNESS~",   
         ~"PART_NUM~".~"OIL_STENCIL_INTERLEAVE~",   
         ~"PART_NUM~".~"PROCESSING_OTHER_SPEC~",   
         ~"PART_NUM~".~"ITEM_ATTACHMENTS~" ,
			part_num.sector, /* Alex Gerlants. 10/03/2016 */ 
			nvl(part_num.trimming_required, 'N') trimming_required, /* Alex Gerlants. 10/17/2016 */
			part_num.trim_type_code, /* Alex Gerlants. 10/17/2016 */
			part_num.incoming_coil_width, /* Alex Gerlants. 10/17/2016 */
			part_num.trimmed_coil_width, /* Alex Gerlants. 10/17/2016 */
			part_num.trimmed_width_override_user, /* Alex Gerlants. 10/17/2016 */
			part_num.trimmed_width_overridden, /* Alex Gerlants. 10/17/2016 */
			(select dimpling_code from dbo.dimpling dimpling where dimpling_code = part_num.dimpling_code) dimpling_code, /* Alex Gerlants. Active_Parts_List */
			nvl(special_part, 'N') special_part, /* Alex Gerlants. 07/18/2022. 1615_Highlight_Item_Note_For_Special_Part */
			die.die_name, /* Alex Gerlants. 02/20/2024. 9999_Work_Center */
			line.line_desc, /* Alex Gerlants. 02/20/2024. 9999_Work_Center */
			spm, /* Alex Gerlants. 02/20/2024. 9999_Work_Center */
			efficiency_percent, /* Alex Gerlants. 02/20/2024. 9999_Work_Center */
			pieces_skid /* Alex Gerlants. 02/20/2024. 9999_Work_Center */
    FROM part_num  
         left outer join die on die.die_id = part_num.die_id
         left outer join line on line.line_num = part_num.line_num 
   WHERE ~"PART_NUM~".~"PART_NUM_ID~" = :item_number       
" arguments=(("item_number", number)) )
