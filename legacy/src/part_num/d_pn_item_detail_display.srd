 column=(type=char(100) updatewhereclause=yes name=packaging_other_spec dbname="part_num.packaging_other_spec" )
 column=(type=decimal(0) updatewhereclause=yes name=item_status dbname="part_num.item_status" values="Active	1/Obsoleted	0/" )
 column=(type=char(255) updatewhereclause=yes name=item_desc dbname="part_num.item_desc" )
 column=(type=char(255) updatewhereclause=yes name=item_note dbname="part_num.item_note" )
 column=(type=char(255) updatewhereclause=yes name=material_end_use dbname="part_num.material_end_use" )
 column=(type=char(255) updatewhereclause=yes name=surface dbname="part_num.surface" )
 column=(type=char(255) updatewhereclause=yes name=flatness dbname="part_num.flatness" )
 column=(type=char(255) updatewhereclause=yes name=oil_stencil_interleave dbname="part_num.oil_stencil_interleave" )
 column=(type=char(255) updatewhereclause=yes name=processing_other_spec dbname="part_num.processing_other_spec" )
 column=(type=char(255) updatewhereclause=yes name=item_attachments dbname="part_num.item_attachments" )
 column=(type=decimal(0) updatewhereclause=yes name=sector dbname="part_num.sector" )
 column=(type=char(1) updatewhereclause=yes name=trimming_required dbname="trimming_required" )
 column=(type=number updatewhereclause=yes name=trim_type_code dbname="trim_type_code" )
 column=(type=decimal(3) updatewhereclause=yes name=incoming_coil_width dbname="incoming_coil_width" )
 column=(type=decimal(3) updatewhereclause=yes name=trimmed_coil_width dbname="trimmed_coil_width" )
