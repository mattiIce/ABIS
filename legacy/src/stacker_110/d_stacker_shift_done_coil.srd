$PBExportHeader$d_stacker_shift_done_coil.srd
$PBExportComments$list all done coils in this shift
release 9;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes hidegrayline=no grid.lines=0 )
header(height=64 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=61 color="536870912" )
table(column=(type=decimal(0) update=yes updatewhereclause=yes key=yes name=shift_num dbname="shift_coil.shift_num" )
 column=(type=decimal(0) update=yes updatewhereclause=yes key=yes name=coil_run_num dbname="shift_coil.coil_run_num" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=ab_job_num dbname="shift_coil.ab_job_num" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=coil_abc_num dbname="shift_coil.coil_abc_num" )
 column=(type=datetime update=yes updatewhereclause=yes name=coil_begin_time dbname="shift_coil.coil_begin_time" )
 column=(type=datetime update=yes updatewhereclause=yes name=coil_end_time dbname="shift_coil.coil_end_time" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"shift_coil~" ) COLUMN(NAME=~"shift_coil.shift_num~") COLUMN(NAME=~"shift_coil.coil_run_num~") COLUMN(NAME=~"shift_coil.ab_job_num~") COLUMN(NAME=~"shift_coil.coil_abc_num~") COLUMN(NAME=~"shift_coil.coil_begin_time~") COLUMN(NAME=~"shift_coil.coil_end_time~")WHERE(    EXP1 =~"~~~"SHIFT_COIL~~~".~~~"SHIFT_NUM~~~"~"   OP =~"=~"    EXP2 =~":al_shift~" ) ) ARG(NAME = ~"al_shift~" TYPE = number) " update="SHIFT_COIL" updatewhere=1 updatekeyinplace=no arguments=(("al_shift", number))  sort="coil_run_num A " )
text(band=header alignment="2" text="Shift Num" border="0" color="33554432" x="7" y="6" height="51" width="227" html.valueishtml="0"  name=shift_num_t visible="1"  font.face="Arial" font.height="-8" font.weight="700"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="536870912" )
text(band=header alignment="2" text="Coil Run Num" border="0" color="33554432" x="241" y="6" height="51" width="318" html.valueishtml="0"  name=coil_run_num_t visible="1"  font.face="Arial" font.height="-8" font.weight="700"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="536870912" )
text(band=header alignment="2" text="Ab Job Num" border="0" color="33554432" x="567" y="6" height="51" width="282" html.valueishtml="0"  name=ab_job_num_t visible="1"  font.face="Arial" font.height="-8" font.weight="700"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="536870912" )
text(band=header alignment="2" text="Coil Abc Num" border="0" color="33554432" x="856" y="6" height="51" width="315" html.valueishtml="0"  name=coil_abc_num_t visible="1"  font.face="Arial" font.height="-8" font.weight="700"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="536870912" )
text(band=header alignment="2" text="Coil Begin Time" border="0" color="33554432" x="1178" y="6" height="51" width="373" html.valueishtml="0"  name=coil_begin_time_t visible="1"  font.face="Arial" font.height="-8" font.weight="700"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="536870912" )
