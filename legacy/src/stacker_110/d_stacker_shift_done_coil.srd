compute(band=detail alignment="0" expression="~"Run# ~" +String(coil_run_num) + ~" ~" +~"Coil# ~" + String( coil_abc_num) + ~" ~" + ~"Job# ~" + String(ab_job_num) + ~" ~" + ~"EndTime: ~"  + String(coil_end_time,~"HH:MM~")"border="0" color="0" x="1891" y="3" height="51" width="260" format="[GENERAL]" html.valueishtml="0"  name=display_t visible="1"  font.face="Arial" font.height="-8" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="16777215" )
