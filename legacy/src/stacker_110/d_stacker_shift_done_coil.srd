column(band=detail id=5 alignment="0" tabsequence=50 border="0" color="33554432" x="1178" y="6" height="48" width="373" format="[shortdate] [time]" html.valueishtml="0"  name=coil_begin_time visible="1" edit.limit=0 edit.case=any edit.focusrectangle=no edit.autoselect=yes edit.autohscroll=yes edit.imemode=0  font.face="Arial" font.height="-8" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="536870912" )
