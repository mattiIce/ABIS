integer height = 93
integer taborder = 11
string facename = "Arial"
string text = "Show me more about this job"
end type

event clicked;call super::clicked;IF il_current_job > 0 THEN 
	OpenWithParm(w_stacker_job_details, il_current_job)
ELSE
	MessageBox("Warning","Please select a job first.")
END IF
RETURN 1
end event

type dw_shape from u_dw within tabpage_summary
event type integer ue_set_w_l ( long al_job )
integer x = 1971
integer y = 16
integer width = 1741
integer height = 582
integer taborder = 21
string dataobject = "d_stacker_x1shape_display"
boolean vscrollbar = false
boolean livescroll = false
end type

event type integer ue_set_w_l(long al_job);Long ll_sum

SELECT SUM(PROCESS_COIL.PROCESS_QUANTITY) INTO :ll_sum
FROM PROCESS_COIL 
WHERE  AB_JOB_NUM = :al_job
USING SQLCA;

this.SetItem(this.GetRow(), "coil_total_wt", ll_sum)
this.ResetUpdate()

RETURN 1





end event

event constructor;call super::constructor;SetTransObject(SQLCA)
end event

event rbuttondown;//override
RETURN 0
end event

event rbuttonup;//override
RETURN 0
end event

event pfc_populatedddw;call super::pfc_populatedddw;IF adwc_obj.SetTransObject(SQLCA) = -1 THEN  
	Return -1  
ELSE   
	Return adwc_obj.Retrieve()  
END IF
end event

event pfc_retrieve;call super::pfc_retrieve;Int li_row
Long ll_order, ll_item
String ls_shape

li_row = tab_tracking.tabpage_summary.dw_job.GetRow()
IF li_row <= 0 THEN Return -1
ls_shape = tab_tracking.tabpage_summary.dw_job.GetItemString(li_row, "order_item_sheet_type", Primary!,TRUE ) 
ll_order = tab_tracking.tabpage_summary.dw_job.GetItemNumber(li_row, "order_item_order_abc_num", Primary!,TRUE ) 
ll_item = tab_tracking.tabpage_summary.dw_job.GetItemNumber(li_row, "order_item_order_item_num", Primary!,TRUE ) 

CHOOSE CASE Upper(Trim(ls_shape))
	CASE "RECTANGLE"
		this.DataObject = "d_stacker_rectangle_display"
	CASE "PARALLELOGRAM"
		this.DataObject = "d_stacker_parallelogram_display"
	CASE "FENDER"
		this.DataObject = "d_stacker_fender_display"
	CASE "CHEVRON"
		this.DataObject = "d_stacker_chevron_display"
	CASE "CIRCLE"
		this.DataObject = "d_stacker_circle_display"
	CASE "TRAPEZOID"
		this.DataObject = "d_stacker_trapezoid_display"
	CASE "L.TRAPEZOID"
		this.DataObject = "d_stacker_ltrapezoid_display"
	CASE "R.TRAPEZOID"
		this.DataObject = "d_stacker_rtrapezoid_display"
	CASE "REINFORCEMENT"
		this.DataObject = "d_stacker_reinforcement_display"
	CASE "LIFTGATE"
		this.DataObject = "d_stacker_liftgate_shape_display"
	CASE ELSE
		this.DataObject = "d_stacker_x1shape_display"
END CHOOSE

SetTransObject(SQLCA)
Return this.Retrieve(ll_item, ll_order )

end event

event pfc_retrievedddw;call super::pfc_retrievedddw;DataWindowChild dddw_cni

IF this.GetChild(as_column, dddw_cni) = -1 THEN
	Return -1
ELSE
	dddw_cni.SetTransObject(SQLCA)
	
	Return dddw_cni.Retrieve() 
END IF
end event

