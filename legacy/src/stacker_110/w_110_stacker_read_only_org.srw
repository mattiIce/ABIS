				tab_tracking.tabpage_real_time.dw_location_13.visible = true
				tab_tracking.tabpage_real_time.dw_location_13.scrolltorow( li_row )
			end if
		case 14
			if not tab_tracking.tabpage_real_time.dw_location_14.visible then
				tab_tracking.tabpage_real_time.dw_location_14.visible = true
				tab_tracking.tabpage_real_time.dw_location_14.scrolltorow( li_row )
			end if
		case 15
