				tab_tracking.tabpage_real_time.dw_location_9.visible = true
				tab_tracking.tabpage_real_time.dw_location_9.scrolltorow( li_row )
			end if
		case 10
			if not tab_tracking.tabpage_real_time.dw_location_10.visible then
				tab_tracking.tabpage_real_time.dw_location_10.visible = true
