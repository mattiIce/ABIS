type tabpage_downtime from userobject within tab_tracking
integer x = 15
integer y = 90
integer width = 3716
integer height = 2179
long backcolor = 15780518
string text = "Shift DownTime"
long tabtextcolor = 33554432
long tabbackcolor = 15780518
long picturemaskcolor = 536870912
dw_dt_gr dw_dt_gr
st_11 st_11
dw_dt_summary dw_dt_summary
st_10 st_10
dw_dt_log dw_dt_log
end type

on tabpage_downtime.create
this.dw_dt_gr=create dw_dt_gr
this.st_11=create st_11
this.dw_dt_summary=create dw_dt_summary
this.st_10=create st_10
this.dw_dt_log=create dw_dt_log
this.Control[]={this.dw_dt_gr,&
this.st_11,&
this.dw_dt_summary,&
this.st_10,&
this.dw_dt_log}
end on

on tabpage_downtime.destroy
destroy(this.dw_dt_gr)
destroy(this.st_11)
destroy(this.dw_dt_summary)
destroy(this.st_10)
destroy(this.dw_dt_log)
end on

