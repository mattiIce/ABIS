event ue_refresh_display();int li_rc, li_i, li_j,li_conveyor, li_row
//st_time.text = string(Now())


li_rc = dw_stack_queue.rowcount( )

if li_rc < 1 then 
	tab_tracking.tabpage_real_time.dw_location_0.visible = false
	tab_tracking.tabpage_real_time.dw_location_1.visible = false
	tab_tracking.tabpage_real_time.dw_location_2.visible = false
	tab_tracking.tabpage_real_time.dw_location_3.visible = false
	tab_tracking.tabpage_real_time.dw_location_4.visible = false
	tab_tracking.tabpage_real_time.dw_location_5.visible = false
	tab_tracking.tabpage_real_time.dw_location_6.visible = false
	tab_tracking.tabpage_real_time.dw_location_7.visible = false
	tab_tracking.tabpage_real_time.dw_location_8.visible = false
	tab_tracking.tabpage_real_time.dw_location_9.visible = false
	tab_tracking.tabpage_real_time.dw_location_10.visible = false
	tab_tracking.tabpage_real_time.dw_location_11.visible = false
	tab_tracking.tabpage_real_time.dw_location_12.visible = false
	tab_tracking.tabpage_real_time.dw_location_13.visible = false
	tab_tracking.tabpage_real_time.dw_location_14.visible = false
	tab_tracking.tabpage_real_time.dw_location_15.visible = false
	tab_tracking.tabpage_real_time.dw_location_16.visible = false
	tab_tracking.tabpage_real_time.dw_location_17.visible = false
	tab_tracking.tabpage_real_time.dw_location_18.visible = false
	return
end if

for li_i=0 to 18
	li_row = dw_stack_queue.find( "location_code=" + string(li_i), 1, li_rc)
	if li_row > 0 then
		choose case li_i
		case 0
			if not tab_tracking.tabpage_real_time.dw_location_0.visible then
				tab_tracking.tabpage_real_time.dw_location_0.visible = true
				tab_tracking.tabpage_real_time.dw_location_0.scrolltorow( li_row )
			end if
		case 1
			if not tab_tracking.tabpage_real_time.dw_location_1.visible then
				tab_tracking.tabpage_real_time.dw_location_1.visible = true
				tab_tracking.tabpage_real_time.dw_location_1.scrolltorow( li_row )
//				dw_conveyor_1.setrow( li_row)
//				cb_scale.enabled = true
//				cb_wt_ack.enabled = true
			end if
		case 2
			if not tab_tracking.tabpage_real_time.dw_location_2.visible then
				tab_tracking.tabpage_real_time.dw_location_2.visible = true
				tab_tracking.tabpage_real_time.dw_location_2.scrolltorow( li_row )
			end if
		case 3
			if not tab_tracking.tabpage_real_time.dw_location_3.visible then
				tab_tracking.tabpage_real_time.dw_location_3.visible = true
				tab_tracking.tabpage_real_time.dw_location_3.scrolltorow( li_row )
			end if
		case 4
			if not tab_tracking.tabpage_real_time.dw_location_4.visible then
				tab_tracking.tabpage_real_time.dw_location_4.visible = true
				tab_tracking.tabpage_real_time.dw_location_4.scrolltorow( li_row )
			end if
		case 5
			if not tab_tracking.tabpage_real_time.dw_location_5.visible then
				tab_tracking.tabpage_real_time.dw_location_5.visible = true
				tab_tracking.tabpage_real_time.dw_location_5.scrolltorow( li_row )
			end if
		case 6
			if not tab_tracking.tabpage_real_time.dw_location_6.visible then
				tab_tracking.tabpage_real_time.dw_location_6.visible = true
				tab_tracking.tabpage_real_time.dw_location_6.scrolltorow( li_row )
			end if
		case 7
