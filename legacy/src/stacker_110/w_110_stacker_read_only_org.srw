event type integer ue_show_shift_info_on_realtime();Long ll_shiftid, ll_job, ll_job_wt, ll_cut_wt, ll_donejob
DateTime ldt_s, ldt_e
String ls_cust, ls_part

SELECT shift_num, ab_job_num INTO :ll_shiftid, :ll_job
FROM line_current_status
WHERE line_num = :ii_line_id
USING SQLCA;

IF ll_shiftid <= 0 OR IsNULL(ll_shiftid) THEN
	tab_tracking.tabpage_real_time.st_shiftinfo.text = "No Shift Running."
	tab_tracking.tabpage_real_time.st_currentjob.Text = ""
	tab_tracking.tabpage_real_time.st_jobrate.Text = ""
	tab_tracking.tabpage_real_time.st_customer.Text = ""
	tab_tracking.tabpage_real_time.st_part.Text = ""
	RETURN 0
END IF
tab_tracking.tabpage_downtime.dw_dt_log.Retrieve(ll_shiftid)
tab_tracking.tabpage_downtime.dw_dt_summary.Retrieve(ll_shiftid)
tab_tracking.tabpage_downtime.dw_dt_gr.Retrieve(ll_shiftid)


SELECT planned_starting_time, planned_ending_time INTO :ldt_s, :ldt_e
FROM Shift
WHERE shift_num = :ll_shiftid
USING SQLCA;
tab_tracking.tabpage_real_time.st_shiftinfo.text = String(ldt_s, "mm/dd/yyyy h:mm AM/PM;'none'") + " - " + String(ldt_e,"mm/dd/yyyy h:mm AM/PM;'none'") 


IF ll_job > 0 THEN
	tab_tracking.tabpage_real_time.st_currentjob.Text = String(ll_job)
	SELECT SUM(prod_item_net_wt) INTO :ll_cut_wt
	FROM Production_sheet_item
	WHERE ab_job_num = :ll_job
	USING SQLCA;
	SELECT job_sheet_wt INTO :ll_job_wt
	FROM ab_job 
	WHERE ab_job_num = :ll_job
	USING SQLCA;
	IF ll_job_wt > 0 THEN 
		tab_tracking.tabpage_real_time.st_jobrate.Text = String(Real(ll_cut_wt)/Real(ll_job_wt)*100.0, "###.#")
	ELSE
		tab_tracking.tabpage_real_time.st_jobrate.Text = "?"
	END IF
ELSE
	tab_tracking.tabpage_real_time.st_currentjob.Text = ""
	tab_tracking.tabpage_real_time.st_jobrate.Text = ""
	tab_tracking.tabpage_real_time.st_customer.Text = ""
	tab_tracking.tabpage_real_time.st_part.Text = ""
	RETURN 0
END IF

SELECT "CUSTOMER"."CUSTOMER_SHORT_NAME",   
       "ORDER_ITEM"."MATERIAL_END_USE"
INTO :ls_cust, :ls_part
FROM "AB_JOB",   
         "CUSTOMER",   
         "ORDER_ITEM",   
         "CUSTOMER_ORDER"  
WHERE    ( "AB_JOB"."ORDER_ITEM_NUM" = "ORDER_ITEM"."ORDER_ITEM_NUM" ) and  
         ( "AB_JOB"."ORDER_ABC_NUM" = "ORDER_ITEM"."ORDER_ABC_NUM" ) and  
         ( "CUSTOMER_ORDER"."ORDER_ABC_NUM" = "AB_JOB"."ORDER_ABC_NUM" ) and  
         ( "CUSTOMER_ORDER"."ORIG_CUSTOMER_ID" = "CUSTOMER"."CUSTOMER_ID" ) and  
         ( "AB_JOB"."AB_JOB_NUM" = :ll_job )
USING SQLCA;

tab_tracking.tabpage_real_time.st_customer.Text = ls_cust
tab_tracking.tabpage_real_time.st_part.Text = ls_part


RETURN 1
end event

event ue_openorder();
IF il_current_job < 1 THEN 
	MessageBox("Error", "Select an order first!", StopSign! )
	RETURN
END IF

gl_message = il_current_job

Close(this)

SetPointer(HourGlass!)
Message.StringParm = "w_production" 
gnv_app.of_getFrame().Event pfc_open()

end event

event type string ue_whoami();Return "w_110_stacker_read_only"
end event

public function integer wf_find_location_in_queue (integer ai_lc);long ll_rc,ll_i
ll_rc = dw_stack_queue.rowcount( )
if ll_rc < 1 then
	return 0
end if

for ll_i=1 to ll_rc
	if dw_stack_queue.object.location_code[ll_i] = ai_lc then
		return ll_i
	end if
next

return 0

end function

public function integer wf_init_stack_queue ();//Retrieve data from line current status table and populate to stack queue!
//Return 0 ok
//return 1 error
long ll_row, ll_rc, ll_skid_id, ll_job, ll_nw
int li_seq_job, li_i
//long ll_loc1, ll_loc2, ll_loc3, ll_loc4, ll_loc5, ll_loc6, ll_loc7
//long ll_loc8, ll_loc9, ll_loc10, ll_loc11, ll_loc12, ll_loc13, ll_loc14
//long ll_loc15, ll_loc16, ll_loc17, ll_loc18
long ll_loc[18]

  SELECT "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_1",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_2",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_3",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_4",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_5",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_6",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_7",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_8",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_9",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_10",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_11",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_12",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_13",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_14",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_15",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_16",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_17",  
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_18"  
    INTO :ll_loc[1],   
         :ll_loc[2],   
         :ll_loc[3],   
         :ll_loc[4],   
         :ll_loc[5],   
         :ll_loc[6],   
         :ll_loc[7],   
         :ll_loc[8],   
         :ll_loc[9],   
         :ll_loc[10],   
         :ll_loc[11],   
         :ll_loc[12],   
         :ll_loc[13],   
         :ll_loc[14],   
         :ll_loc[15],   
         :ll_loc[16],   
         :ll_loc[17], 
         :ll_loc[18]  
   FROM "LINE_CURRENT_STATUS"  
   WHERE "LINE_CURRENT_STATUS"."LINE_NUM" = :ii_line_id;

	dw_stack_queue.reset( )
	for li_i=1 to 18
		if (not isNull(ll_loc[li_i])) and ll_loc[li_i] > 1000 then
			ll_skid_id = ll_loc[li_i]
			SELECT "SHEET_SKID"."AB_JOB_NUM",   
         		"SHEET_SKID"."SHEET_NET_WT",   
         		"SHEET_SKID"."SKID_SEQ_FOR_JOB"  
    		INTO :ll_job ,   
         		:ll_nw ,   
         		:li_seq_job  
    		FROM "SHEET_SKID"  
   		WHERE "SHEET_SKID"."SHEET_SKID_NUM" = :ll_skid_id   
           	;
			ll_row = dw_stack_queue.insertrow( 0 )	
			dw_stack_queue.object.sheet_skid_num[ll_row] = ll_skid_id
			dw_stack_queue.object.ab_job_num[ll_row] = ll_job
			dw_stack_queue.object.skid_seq_for_job[ll_row] = li_seq_job
			dw_stack_queue.object.sheet_net_wt[ll_row] = ll_nw
			dw_stack_queue.object.location_code[ll_row] = li_i
			choose case li_i
			case 0,1
				dw_stack_queue.object.conveyor[ll_row] = 0
			case 2,3,4
				dw_stack_queue.object.conveyor[ll_row] = 1
			case 5,6
				dw_stack_queue.object.conveyor[ll_row] = 2
			case 7,8,9,10
				dw_stack_queue.object.conveyor[ll_row] = 3
			case 11,12
				dw_stack_queue.object.conveyor[ll_row] = 4
			case 13
				dw_stack_queue.object.conveyor[ll_row] = 7
			case 14,15
				dw_stack_queue.object.conveyor[ll_row] = 5
			case 16,17,18
				dw_stack_queue.object.conveyor[ll_row] = 6
			end choose
		end if
	next
return 0
end function

public subroutine wf_opc_weight_ack ();
end subroutine

