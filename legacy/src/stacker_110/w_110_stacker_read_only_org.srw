end event

on tabpage_summary.create
this.cb_details=create cb_details
this.dw_shape=create dw_shape
this.st_9=create st_9
this.st_8=create st_8
this.dw_skid=create dw_skid
this.dw_coil=create dw_coil
this.dw_job=create dw_job
this.tv_110=create tv_110
this.Control[]={this.cb_details,&
this.dw_shape,&
this.st_9,&
this.st_8,&
this.dw_skid,&
this.dw_coil,&
this.dw_job,&
this.tv_110}
end on

on tabpage_summary.destroy
destroy(this.cb_details)
destroy(this.dw_shape)
destroy(this.st_9)
destroy(this.st_8)
destroy(this.dw_skid)
destroy(this.dw_coil)
destroy(this.dw_job)
destroy(this.tv_110)
end on

type cb_details from u_cb within tabpage_summary
integer x = 1649
integer y = 2074
