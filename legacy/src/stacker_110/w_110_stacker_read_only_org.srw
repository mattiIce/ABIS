on w_110_stacker_read_only_org.create
int iCurrent
call super::create
this.cb_refresh=create cb_refresh
this.cb_exit=create cb_exit
this.dw_stack_queue=create dw_stack_queue
this.st_1=create st_1
this.tab_tracking=create tab_tracking
iCurrent=UpperBound(this.Control)
this.Control[iCurrent+1]=this.cb_refresh
this.Control[iCurrent+2]=this.cb_exit
this.Control[iCurrent+3]=this.dw_stack_queue
this.Control[iCurrent+4]=this.st_1
this.Control[iCurrent+5]=this.tab_tracking
end on

on w_110_stacker_read_only_org.destroy
call super::destroy
destroy(this.cb_refresh)
destroy(this.cb_exit)
destroy(this.dw_stack_queue)
destroy(this.st_1)
destroy(this.tab_tracking)
end on

