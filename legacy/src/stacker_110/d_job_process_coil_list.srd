 column=(type=char(18) updatewhereclause=yes name=coil_lot_num dbname="coil.lot_num" values="Done	0/Processing	1/New	2/Rejected	3/OnHold	4/Return	6/Rebanded	7/Retry	8/" )
 column=(type=decimal(0) updatewhereclause=yes name=coil_coil_abc_num dbname="coil.coil_abc_num" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=process_coil_ab_job_num dbname="process_coil.ab_job_num" )
