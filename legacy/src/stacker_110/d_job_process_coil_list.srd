 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"coil~" )  TABLE(NAME=~"process_coil~" ) COLUMN(NAME=~"coil.coil_org_num~") COLUMN(NAME=~"process_coil.coil_abc_num~") COLUMN(NAME=~"process_coil.process_quantity~") COLUMN(NAME=~"process_coil.process_date~") COLUMN(NAME=~"coil.lot_num~") COLUMN(NAME=~"coil.coil_abc_num~") COLUMN(NAME=~"process_coil.ab_job_num~") COLUMN(NAME=~"coil.recovery_rate~") COLUMN(NAME=~"process_coil.process_end_wt~") COLUMN(NAME=~"process_coil.shift_process_status~")    JOIN (LEFT=~"coil.coil_abc_num~"    OP =~"=~"RIGHT=~"process_coil.coil_abc_num~" )WHERE(    EXP1 =~"~~~"PROCESS_COIL~~~".~~~"COIL_ABC_NUM~~~"~"   OP =~"=~"    EXP2 =~"~~~"COIL~~~".~~~"COIL_ABC_NUM~~~"~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"PROCESS_COIL~~~".~~~"AB_JOB_NUM~~~"~"   OP =~"=~"    EXP2 =~":ai_ab_job_num~" ) ) ARG(NAME = ~"ai_ab_job_num~" TYPE = number) " arguments=(("ai_ab_job_num", number))  sort="process_coil_coil_abc_num D " )
