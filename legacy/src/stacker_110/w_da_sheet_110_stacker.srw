event clicked;call super::clicked;long ll_skid_id, ll_row
if dw_location_8.visible then
	ll_row = wf_find_location_in_queue( 8)
	if ll_row > 0 then 
		ll_skid_id = dw_stack_queue.object.sheet_skid_num[ll_row ]
		openwithparm(iw_qc_sheet_selected, ll_skid_id , parent)
	end if
elseif dw_location_7.visible then
	ll_row = wf_find_location_in_queue( 7)
	if ll_row > 0 then
		ll_skid_id = dw_stack_queue.object.sheet_skid_num[ll_row ]
		openwithparm(iw_qc_sheet_selected, ll_skid_id , parent)
	end if
else
	MessageBox("Error", "Stack not in Conveyor 3, Can not update dimentional check data!")
	return 0
end if
end event

