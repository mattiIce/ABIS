event ue_retrieve_wt();long ll_nw
itmg_1_second_scale.inv_single.of_unregister( )
ll_nw = of_get_scale_wt( )


long ll_row, ll_skid_id, ll_rc, ll_skid_old_wt, ll_item_wt, ll_prod_item_id, ll_other_wt
int li_location, li_item_count
if dw_location_3.visible then
//	ll_nw = f_read_scale_cardinal( ii_com_port )
	li_location = 3
elseif dw_location_4.visible then
//	ll_nw = f_read_scale_cardinal( ii_com_port )
	li_location = 4
//elseif dw_location_4.visible then
//	//
else
//	MessageBox("Error", "Stack not on Conveyor1!, Can not read scale.")
		mle_log.text = mle_log.text + "~r~nStack not on Conveyor1!, Can not read scale.!"

	return
end if


if ll_nw < 10 or ll_nw > 39000 then
//	MessageBox("Error", String(ll_nw) + " LB is not valid weight!" )
	mle_log.text = mle_log.text + "~r~nInvalid weight!!"
	return
else
	ll_row = dw_stack_queue.find( "location_code=" + string(li_location), 1, dw_stack_queue.rowcount( ) )
	if ll_row < 1 then return
	ll_skid_id = dw_stack_queue.object.sheet_skid_num[ll_row]
	//Update sheet_skid and production_item table
	ll_skid_old_wt = dw_stack_queue.object.sheet_net_wt[ll_row]
	if isNull( ll_skid_old_wt ) then ll_skid_old_wt = 0
	
	if ABS(ll_nw - ll_skid_old_wt) < 1 then return
	
	
	sqlca.update_sheet_skid_wt( ll_skid_id , ll_nw )
	
//	UPDATE "SHEET_SKID"  
//     SET "SHEET_NET_WT" = :ll_nw 
//   WHERE "SHEET_SKID"."SHEET_SKID_NUM" = :ll_skid_id   
//           ;
//	ll_rc = sqlca.sqlcode
//	  if ll_rc <> 0 then
//		sqlca.of_rollback( ) ;
//		MessageBox("Database error", "Can not update sheet skid!")
//		return ll_rc
//	end if
//	  ll_item_wt = ll_nw - ll_skid_old_wt
	  
//	  SELECT COUNT(*),max(PROD_ITEM_NUM) INTO :li_item_count, :ll_prod_item_id
//		FROM SHEET_SKID_DETAIL
//		WHERE SHEET_SKID_NUM = :ll_skid_id;
//	  
//	  	if li_item_count > 1 then
//	  		UPDATE "PRODUCTION_SHEET_ITEM"  
//     		SET "PROD_ITEM_NET_WT" = :ll_item_wt  
//   		WHERE "PROD_ITEM_NUM"   in (
//			SELECT "PROD_ITEM_NUM"
//			FROM "SHEET_SKID_DETAIL"
//			WHERE "SHEET_SKID_NUM" = :ll_skid_id) and
//			"PROD_ITEM_NET_WT" = 0
//           ;
//		else
//			UPDATE "PRODUCTION_SHEET_ITEM"  
//     		SET "PROD_ITEM_NET_WT" = :ll_nw  
//   		WHERE "PROD_ITEM_NUM"   in (
//			SELECT "PROD_ITEM_NUM"
//			FROM "SHEET_SKID_DETAIL"
//			WHERE "SHEET_SKID_NUM" = :ll_skid_id) 
//           ;
//		end if
//
//	ll_rc = sqlca.sqlcode
//	  if ll_rc <> 0 then
//		sqlca.of_rollback( ) ;
//		MessageBox("Database error", "Can not update sheet skid!")
//		return ll_rc
//		end if
	//end of update
	
//	sqlca.of_commit( )
	
	dw_stack_queue.object.sheet_net_wt[ll_row] = ll_nw
	
	choose case li_location
	case 3
		dw_location_3.object.sheet_net_wt[1] = ll_nw
	case 4
		dw_location_4.object.sheet_net_wt[1] = ll_nw
	end choose
end if


end event

