type ole_1 from olecustomcontrol within w_da_sheet_110_stacker
event onconnect ( )
event ondisconnect ( )
event ondatachanged ( integer bokay,  oleobject changeditems )
event onwritecompleted ( integer bokay,  oleobject writtenitems )
event onerror ( long ocx_error,  string description )
integer x = 241
integer y = 109
integer width = 176
integer height = 122
integer taborder = 20
borderstyle borderstyle = stylelowered!
boolean focusrectangle = false
string binarykey = "w_da_sheet_110_stacker.win"
integer binaryindex = 1
integer textsize = -12
integer weight = 400
fontcharset fontcharset = ansi!
fontpitch fontpitch = variable!
fontfamily fontfamily = swiss!
string facename = "Arial"
long textcolor = 33554432
end type

event ondatachanged(integer bokay, oleobject changeditems);if not ib_post_open then
	return
end if
int li_count, li_i, li_temp
long ll_value
boolean lb_value
string ls_tag
//Real lr_feedlength, lr_rejectlength
li_count = changeditems.count
//Time lt_data_change_time
for li_i= 0 to li_count - 1
	ls_tag = changeditems.item(li_i).ItemId
	
	choose case ls_tag
		case is_idleconveyor1weightack
//			uo_autorunning.set_select(ib_autorunning)
				lb_value = changeditems.item(li_i).value
				if lb_value then 
					cb_wt_ack.enabled = false
				else
					cb_wt_ack.enabled = true
				end if
		case is_scaleremoteack
//			ib_coilinfeeder = changeditems.item(li_i).value
		case is_sendblanktosta1
			ib_sendblanktosta1 = changeditems.item(li_i).value
			p_blank2_sta1.visible = ib_sendblanktosta1
			st_sta1_count.visible = ib_sendblanktosta1
		case is_sendblanktosta2
			lb_value = changeditems.item(li_i).value
			ib_sendblanktosta2 = lb_value
			p_blank2_sta2.visible = lb_value
			st_sta2_count.visible = lb_value
		case is_slavesta2tosta1
			lb_value = changeditems.item(li_i).value
			ib_slavesta2tosta1 = lb_value
			uo_sta2_slave_sta1.set_select( lb_value )
		case is_sta1stackcomplete
			ib_sta1_complete = changeditems.item(li_i).value
			uo_sta1_complete.set_select( ib_sta1_complete )
			if ib_sta1_complete then
				parent.postevent("ue_sta1_complete")
			end if
		case is_sta2stackcomplete
			ib_sta2_complete = changeditems.item(li_i).value
			uo_sta2_complete.set_select( ib_sta2_complete )
			if ib_sta2_complete then
				parent.postevent("ue_sta2_complete")
			end if
		case is_stackatcenterofconveyor3
			ib_stackatcenterofconveyor3 = changeditems.item(li_i).value
			uo_at_center_conv3 .set_select( ib_stackatcenterofconveyor3 )
			if ib_stackatcenterofconveyor3 then
				parent.postevent( "ue_at_center_conv3")
			end if
		case is_stackatcenterofwrapper1unloadconveyor
			ib_stackatcenterofwrapper1unloadconveyor  = changeditems.item(li_i).value
			uo_at_center_wp1_unload_conv .set_select( ib_stackatcenterofwrapper1unloadconveyor )
			if ib_stackatcenterofwrapper1unloadconveyor then
				parent.postevent( "ue_at_center_wp1_unload_conv")
			else
				parent.postevent("ue_stack_unloaded_from_wp1_unload_conv")
			end if
		case is_stackatendofwrapper2unloadconveyor
			ib_stackatendofwrapper2unloadconveyor = changeditems.item(li_i).value
			uo_at_end_wp2_unload_conv .set_select( ib_stackatendofwrapper2unloadconveyor )
			if ib_stackatendofwrapper2unloadconveyor then
				parent.postevent( "ue_at_end_wp2_unload_conv")
			else
				parent.postevent( "ue_stack_unloaded_from_wp2_unload_conv")
			end if
		case is_stackenteringconveyor1
			ib_stackenteringconveyor1 = changeditems.item(li_i).value
			uo_enter_conv1.set_select( ib_stackenteringconveyor1 )
			if ib_stackenteringconveyor1 then
				parent.postevent( "ue_entering_conv1")
			end if
		case is_stackenteringwrapper1	
			ib_stackenteringwrapper1 = changeditems.item(li_i).value
			uo_enter_wrapper1 .set_select( ib_stackenteringwrapper1 )
			if ib_stackenteringwrapper1 then
				parent.postevent( "ue_entering_wp1")
			end if
		case is_stackenteringwrapper2
			ib_stackenteringwrapper2 = changeditems.item(li_i).value
			uo_enter_wp2 .set_select( ib_stackenteringwrapper2 )
			if ib_stackenteringwrapper2 then
				parent.postevent( "ue_entering_wp2")
			end if
		case is_stacker_auto_enable
			lb_value = changeditems.item(li_i).value
			uo_autoenable .set_select( lb_value )

		case is_stackerinauto
			lb_value = changeditems.item(li_i).value
			uo_automode .set_select( lb_value )

		case is_stackerinmanual
			lb_value = changeditems.item(li_i).value
			uo_manualmode .set_select( lb_value )

		case is_stackleavingconveyor1
			ib_stackleavingconveyor1 = changeditems.item(li_i).value
			uo_leaving_conv1.set_select( ib_stackleavingconveyor1 )
			if ib_stackleavingconveyor1 then
				parent.postevent( "ue_leaving_conv1")
			end if
		case is_stackleavingconveyor2	
			ib_stackleavingconveyor2 = changeditems.item(li_i).value
			uo_leaving_conv2 .set_select( ib_stackleavingconveyor2 )
			if ib_stackleavingconveyor2 then
				parent.postevent( "ue_leaving_conv2")
			end if
		case is_stackleavingsta1lifttblconveyor
			ib_stackleavingsta1lifttblconveyor = changeditems.item(li_i).value
			uo_leaving_sta1.set_select( ib_stackleavingsta1lifttblconveyor )
			if ib_stackleavingsta1lifttblconveyor then
				parent.postevent( "ue_leaving_sta1_lift_tbl_conv")
			end if
		case is_stackleavingsta2lifttblconveyor
			ib_stackleavingsta2lifttblconveyor = changeditems.item(li_i).value
			uo_leaving_sta2.set_select( ib_stackleavingsta2lifttblconveyor )
			if ib_stackleavingsta2lifttblconveyor then
				parent.postevent( "ue_leaving_sta2_lift_tbl_conv")
			end if
	case is_stackleavingwrapper1
			ib_stackleavingwrapper1 = changeditems.item(li_i).value
			uo_leaving_wp1 .set_select( ib_stackleavingwrapper1 )
			if ib_stackleavingwrapper1 then
				parent.postevent( "ue_leaving_wp1")
			end if
	case is_stackleavingwrapper2
			ib_stackleavingwrapper2 = changeditems.item(li_i).value
			uo_leaving_wp2 .set_select( ib_stackleavingwrapper2 )
			if ib_stackleavingwrapper2 then
				parent.postevent( "ue_leaving_wp2")
			end if
	case is_stackonconveyor1
			ib_stackonconveyor1 = changeditems.item(li_i).value
			uo_on_conv1.set_select( ib_stackonconveyor1 )
			if ib_stackonconveyor1 then
				parent.postevent( "ue_on_conv1")
			end if
	case is_stackonconveyor2
			ib_stackonconveyor2 = changeditems.item(li_i).value
			uo_on_conv2 .set_select( ib_stackonconveyor2 )
			if ib_stackonconveyor2 then
				parent.postevent( "ue_on_conv2")
			end if
	case is_stackonconveyor3
			ib_stackonconveyor3 = changeditems.item(li_i).value
			uo_on_conv3 .set_select( ib_stackonconveyor3 )
			if ib_stackonconveyor3 then
				parent.postevent( "ue_on_conv3")
			end if
	case is_stackonwrapper1unloadconveyor
			ib_stackonwrapper1unloadconveyor = changeditems.item(li_i).value
			uo_on_wp1_unload_conv .set_select( ib_stackonwrapper1unloadconveyor )
			if ib_stackonwrapper1unloadconveyor then
				parent.postevent( "ue_on_wp1_unload_conv")
			end if

	case is_stackonwrapper2loadconveyor
			ib_stackonwrapper2loadconveyor = changeditems.item(li_i).value
			uo_on_wp2_load_conv .set_select( ib_stackonwrapper2loadconveyor )
			if ib_stackonwrapper2loadconveyor then
				parent.postevent( "ue_on_wp2_load_conv")
			end if
	case is_stackonwrapper2unloadconveyor
			ib_stackonwrapper2unloadconveyor = changeditems.item(li_i).value
			uo_on_wp2_unload_conv .set_select( ib_stackonwrapper2unloadconveyor )
			if ib_stackonwrapper2unloadconveyor then
				parent.postevent( "ue_on_wp2_unload_conv")
			end if
//	case is_HMI_PBs_EndWrap1
//		ib_HMI_PBs_EndWrap1 = changeditems.item(li_i).value
//		if ib_HMI_PBs_EndWrap1 then
//			parent.postevent( "ue_HMI_PBs_EndWrap1")
//		end if
	case is_wrapper1_end_wrapped
		ib_wrapper1_end_wrapped = changeditems.item(li_i).value
		if ib_wrapper1_end_wrapped then
			cb_end_wp1_ack.enabled = false
			parent.postevent( "ue_wrapper1_end_wrapped")
		else
			cb_end_wp1_ack.enabled = true
		end if
	

	case is_stackremovedfromsta1
			//
	case is_stackremovedfromsta2
			//
	case is_station1_stack_counter
			ll_value = changeditems.item(li_i).value
			st_sta1_count.text = String(ll_value)
	case is_station2_stack_counter
			ll_value = changeditems.item(li_i).value
			st_sta2_count.text = String(ll_value)
	case is_inscrapmode
			lb_value = changeditems.item(li_i).value
			uo_scrapmode.set_select(lb_value)
			//st_sta2_count.text = String(ll_value)
	case else
		//
	end choose

next










end event

event onerror(long ocx_error, string description);if parent.of_messagebox( "opc_error", "Error connecting to OPC server", "Serious error! Click ok to save your work and exit. Please call technical support!", StopSign!, OK! , 1) = 1 then
	parent.event pfc_close()
	HALT Close
end if
end event

