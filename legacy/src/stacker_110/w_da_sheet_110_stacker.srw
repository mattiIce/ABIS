event ue_entering_conv1();
//User event entering IDLE conveyor 1

int li_rc, li_rc1, li_rc0

li_rc0 = wf_find_location_in_queue( 0)
li_rc1 = wf_find_location_in_queue( 1)

if wf_find_location_in_queue( 2) > 0 then return

if li_rc0 > 0 and li_rc1 > 0 then
	mle_log.text = mle_log.text + "~r~nEntering conv1 find stack1&2 on both lift-tables. One stack at a time please!"
	return
elseif li_rc0 < 1 and li_rc1 < 1 then
	mle_log.text = mle_log.text + "~r~nEntering conv1 Can not find stack on either lift-table"
	return
else
	li_rc = max( li_rc0 , li_rc1 )
end if

//li_rc = wf_find_location_in_queue( 1 )
if li_rc > 0 then
	dw_stack_queue.object.location_code[li_rc] = 2
	dw_stack_queue.object.conveyor[li_rc] = 0
	else
	mle_log.text = mle_log.text + "~r~nEntering conv1 can not find previous location!"
end if
event ue_refresh_display( )
wf_update_line_current_status()
end event

event ue_on_conv1();

int li_rc
if wf_find_location_in_queue( 3) > 0 then return
li_rc = wf_find_location_in_queue( 2 )
if li_rc > 0 then
	dw_stack_queue.object.location_code[li_rc] = 3
	dw_stack_queue.object.conveyor[li_rc] = 1
	else
	mle_log.text = mle_log.text + "~r~nOn conv1 can not find previous location!"
end if
event ue_refresh_display( )
wf_update_line_current_status()
end event

event ue_leaving_conv1();int li_rc
if wf_find_location_in_queue( 4) > 0 then return
li_rc = wf_find_location_in_queue( 3 )
if li_rc > 0 then
	dw_stack_queue.object.location_code[li_rc] = 4
	dw_stack_queue.object.conveyor[li_rc] = 1
	else
	mle_log.text = mle_log.text + "~r~nLeaving conv1 can not find previous location!"
end if
event ue_refresh_display( )
if cbx_auto_retrieve.checked then cb_scale.event clicked( )
wf_update_line_current_status()
end event

