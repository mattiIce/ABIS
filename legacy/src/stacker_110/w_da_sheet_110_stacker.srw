	if wf_find_location_in_queue( li_loc_now - 1 ) < 1 then
//		this.object.location_code[row] = li_loc_now - 1
		
		choose case li_stacker
		case 1
		 	dw_stack_queue.object.location_code[ll_row_selected] = 0
		case 2
			dw_stack_queue.object.location_code[ll_row_selected] = 1
		end choose

		
