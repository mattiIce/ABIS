event clicked;call super::clicked;long ll_row,ll_row_selected
this.accepttext( )
if row < 1 then return 0
int li_loc_now
li_loc_now = this.object.location_code[row]
ll_row_selected = wf_find_location_in_queue( li_loc_now)
if dwo.Name = "compute_b" and li_loc_now > 0 then
	if wf_find_location_in_queue( li_loc_now - 1 ) < 1 then
//		this.object.location_code[row] = li_loc_now - 1
		dw_stack_queue.object.location_code[ll_row_selected] = li_loc_now - 1
		parent.postevent( "ue_refresh_display" )
		parent.postevent( "ue_refresh_line_current_status" )
	end if
end if
if dwo.Name = "compute_f" and li_loc_now < 18 then
	if wf_find_location_in_queue( li_loc_now + 1 ) < 1 then
//		this.object.location_code[row] = li_loc_now + 1
		dw_stack_queue.object.location_code[ll_row_selected] = li_loc_now + 1
		parent.postevent( "ue_refresh_display" )
		parent.postevent( "ue_refresh_line_current_status" )
	end if
end if

