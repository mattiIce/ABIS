public function integer wf_find_location_in_queue (integer ai_lc);long ll_rc,ll_i
ll_rc = dw_stack_queue.rowcount( )
if ll_rc < 1 then
	return 0
end if

for ll_i=1 to ll_rc
	if dw_stack_queue.object.location_code[ll_i] = ai_lc then
		return ll_i
	end if
next

return 0

end function

public function integer wf_init_stack_queue ();//Retrieve data from line current status table and populate to stack queue!
//Return 0 ok
//return 1 error
long ll_row, ll_rc, ll_skid_id, ll_job, ll_nw, ll_coil, ll_item
int li_seq_job, li_i
long ll_loc1, ll_loc2, ll_loc3, ll_loc4, ll_loc5, ll_loc6, ll_loc7
long ll_loc8, ll_loc9, ll_loc10, ll_loc11, ll_loc12, ll_loc13, ll_loc14
long ll_loc15, ll_loc16, ll_loc17, ll_loc18
long ll_loc[18]

  SELECT "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_1",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_2",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_3",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_4",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_5",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_6",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_7",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_8",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_9",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_10",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_11",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_12",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_13",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_14",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_15",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_16",   
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_17",  
         "LINE_CURRENT_STATUS"."SHEET_SKID_LOCATION_18"  
    INTO :ll_loc[1],   
         :ll_loc[2],   
         :ll_loc[3],   
         :ll_loc[4],   
         :ll_loc[5],   
         :ll_loc[6],   
         :ll_loc[7],   
         :ll_loc[8],   
         :ll_loc[9],   
         :ll_loc[10],   
         :ll_loc[11],   
         :ll_loc[12],   
         :ll_loc[13],   
         :ll_loc[14],   
         :ll_loc[15],   
         :ll_loc[16],   
         :ll_loc[17], 
         :ll_loc[18]  
   FROM "LINE_CURRENT_STATUS"  
   WHERE "LINE_CURRENT_STATUS"."LINE_NUM" = :ii_line_id;

	for li_i=1 to 18
		if (not isNull(ll_loc[li_i])) and ll_loc[li_i] > 1000 then
			ll_skid_id = ll_loc[li_i]
			SELECT "SHEET_SKID"."AB_JOB_NUM",   
         		"SHEET_SKID"."SHEET_NET_WT",   
         		"SHEET_SKID"."SKID_SEQ_FOR_JOB"  
    		INTO :ll_job ,   
         		:ll_nw ,   
         		:li_seq_job  
    		FROM "SHEET_SKID"  
   		WHERE "SHEET_SKID"."SHEET_SKID_NUM" = :ll_skid_id   
           	;
			
			select max(sheet_skid_detail.prod_item_num) into :ll_item
				from sheet_skid_detail
				where sheet_skid_detail.sheet_skid_num = :ll_skid_id;
			
			select production_sheet_item.coil_abc_num into :ll_coil
				from production_sheet_item
			where production_sheet_item.prod_item_num = :ll_item;
			
			
			ll_row = dw_stack_queue.insertrow( 0 )	
			dw_stack_queue.object.sheet_skid_num[ll_row] = ll_skid_id
			dw_stack_queue.object.ab_job_num[ll_row] = ll_job
			dw_stack_queue.object.skid_seq_for_job[ll_row] = li_seq_job
			dw_stack_queue.object.sheet_net_wt[ll_row] = ll_nw
			dw_stack_queue.object.location_code[ll_row] = li_i
			dw_stack_queue.object.coil_abc_num[ll_row] = ll_coil
			choose case li_i
			case 0,1
				dw_stack_queue.object.conveyor[ll_row] = 0
			case 2,3,4
				dw_stack_queue.object.conveyor[ll_row] = 1
			case 5,6
				dw_stack_queue.object.conveyor[ll_row] = 2
			case 7,8,9,10
				dw_stack_queue.object.conveyor[ll_row] = 3
			case 11,12
				dw_stack_queue.object.conveyor[ll_row] = 4
			case 13
				dw_stack_queue.object.conveyor[ll_row] = 7
			case 14,15
				dw_stack_queue.object.conveyor[ll_row] = 5
			case 16,17,18
				dw_stack_queue.object.conveyor[ll_row] = 6
			end choose
		end if
	next
return 0
end function

public function integer wf_update_line_current_status ();//Update line current status table with stack queue

long ll_row, ll_rc, ll_skid_id, ll_i
int li_loc

ll_rc = dw_stack_queue.rowcount( )
if ll_rc < 1 then 
	UPDATE "LINE_CURRENT_STATUS"  
     SET "SHEET_SKID_LOCATION_0" = null,   
         "SHEET_SKID_LOCATION_1" = null,   
         "SHEET_SKID_LOCATION_2" = null,   
         "SHEET_SKID_LOCATION_3" = null,   
         "SHEET_SKID_LOCATION_4" = null,   
         "SHEET_SKID_LOCATION_5" = null,   
         "SHEET_SKID_LOCATION_6" = null,   
         "SHEET_SKID_LOCATION_7" = null,   
         "SHEET_SKID_LOCATION_8" = null,   
         "SHEET_SKID_LOCATION_9" = null,   
         "SHEET_SKID_LOCATION_10" = null,   
         "SHEET_SKID_LOCATION_11" = null,   
         "SHEET_SKID_LOCATION_12" = null,   
         "SHEET_SKID_LOCATION_13" = null,   
         "SHEET_SKID_LOCATION_14" = null,   
         "SHEET_SKID_LOCATION_15" = null,   
         "SHEET_SKID_LOCATION_16" = null,   
         "SHEET_SKID_LOCATION_17" = null,   
         "SHEET_SKID_LOCATION_18" = null  
   WHERE "LINE_CURRENT_STATUS"."LINE_NUM" = :ii_line_id   
           ;
	if sqlca.sqlcode <> 0 then
			sqlca.of_rollback( )
//			return -1
	else
		sqlca.of_commit( )	
	end if
//	event ue_refresh_display_insert_delete( )
	return -1
end if
	
	  UPDATE "LINE_CURRENT_STATUS"  
     SET "SHEET_SKID_LOCATION_0" = null,   
         "SHEET_SKID_LOCATION_1" = null,   
         "SHEET_SKID_LOCATION_2" = null,   
         "SHEET_SKID_LOCATION_3" = null,   
         "SHEET_SKID_LOCATION_4" = null,   
         "SHEET_SKID_LOCATION_5" = null,   
         "SHEET_SKID_LOCATION_6" = null,   
         "SHEET_SKID_LOCATION_7" = null,   
         "SHEET_SKID_LOCATION_8" = null,   
         "SHEET_SKID_LOCATION_9" = null,   
         "SHEET_SKID_LOCATION_10" = null,   
         "SHEET_SKID_LOCATION_11" = null,   
         "SHEET_SKID_LOCATION_12" = null,   
         "SHEET_SKID_LOCATION_13" = null,   
         "SHEET_SKID_LOCATION_14" = null,   
         "SHEET_SKID_LOCATION_15" = null,   
         "SHEET_SKID_LOCATION_16" = null,   
         "SHEET_SKID_LOCATION_17" = null,   
         "SHEET_SKID_LOCATION_18" = null  
   WHERE "LINE_CURRENT_STATUS"."LINE_NUM" = :ii_line_id   
           ;
	if sqlca.sqlcode <> 0 then
			sqlca.of_rollback( )
			return -1
	end if



for ll_i=1 to ll_rc
	li_loc = dw_stack_queue.object.location_code[ll_i]
	ll_skid_id = dw_stack_queue.object.sheet_skid_num[ll_i]
	choose case li_loc
	case 0
		  UPDATE "LINE_CURRENT_STATUS"  
     		SET "SHEET_SKID_LOCATION_0" = :ll_skid_id  
   		WHERE "LINE_CURRENT_STATUS"."LINE_NUM" = :ii_line_id   
           ;
	case 1
		  UPDATE "LINE_CURRENT_STATUS"  
     		SET "SHEET_SKID_LOCATION_1" = :ll_skid_id  
   		WHERE "LINE_CURRENT_STATUS"."LINE_NUM" = :ii_line_id   
           ;
	case 2
			  UPDATE "LINE_CURRENT_STATUS"  
     		SET "SHEET_SKID_LOCATION_2" = :ll_skid_id  
   		WHERE "LINE_CURRENT_STATUS"."LINE_NUM" = :ii_line_id   
           ;
		case 3
			  UPDATE "LINE_CURRENT_STATUS"  
     		SET "SHEET_SKID_LOCATION_3" = :ll_skid_id  
   		WHERE "LINE_CURRENT_STATUS"."LINE_NUM" = :ii_line_id   
           ;
		case 4
			  UPDATE "LINE_CURRENT_STATUS"  
     		SET "SHEET_SKID_LOCATION_4" = :ll_skid_id  
   		WHERE "LINE_CURRENT_STATUS"."LINE_NUM" = :ii_line_id   
           ;
		case 5
			  UPDATE "LINE_CURRENT_STATUS"  
     		SET "SHEET_SKID_LOCATION_5" = :ll_skid_id  
   		WHERE "LINE_CURRENT_STATUS"."LINE_NUM" = :ii_line_id   
           ;
		case 6
			  UPDATE "LINE_CURRENT_STATUS"  
     		SET "SHEET_SKID_LOCATION_6" = :ll_skid_id  
   		WHERE "LINE_CURRENT_STATUS"."LINE_NUM" = :ii_line_id   
           ;
		case 7
			  UPDATE "LINE_CURRENT_STATUS"  
     		SET "SHEET_SKID_LOCATION_7" = :ll_skid_id  
   		WHERE "LINE_CURRENT_STATUS"."LINE_NUM" = :ii_line_id   
           ;
		case 8
			  UPDATE "LINE_CURRENT_STATUS"  
     		SET "SHEET_SKID_LOCATION_8" = :ll_skid_id  
   		WHERE "LINE_CURRENT_STATUS"."LINE_NUM" = :ii_line_id   
           ;
		case 9
			  UPDATE "LINE_CURRENT_STATUS"  
     		SET "SHEET_SKID_LOCATION_9" = :ll_skid_id  
   		WHERE "LINE_CURRENT_STATUS"."LINE_NUM" = :ii_line_id   
           ;
		case 10
			  UPDATE "LINE_CURRENT_STATUS"  
     		SET "SHEET_SKID_LOCATION_10" = :ll_skid_id  
   		WHERE "LINE_CURRENT_STATUS"."LINE_NUM" = :ii_line_id   
           ;
		case 11
			  UPDATE "LINE_CURRENT_STATUS"  
     		SET "SHEET_SKID_LOCATION_11" = :ll_skid_id  
   		WHERE "LINE_CURRENT_STATUS"."LINE_NUM" = :ii_line_id   
           ;
		case 12
			  UPDATE "LINE_CURRENT_STATUS"  
     		SET "SHEET_SKID_LOCATION_12" = :ll_skid_id  
   		WHERE "LINE_CURRENT_STATUS"."LINE_NUM" = :ii_line_id   
           ;
		case 13
			  UPDATE "LINE_CURRENT_STATUS"  
     		SET "SHEET_SKID_LOCATION_13" = :ll_skid_id  
   		WHERE "LINE_CURRENT_STATUS"."LINE_NUM" = :ii_line_id   
           ;
		case 14
			  UPDATE "LINE_CURRENT_STATUS"  
     		SET "SHEET_SKID_LOCATION_14" = :ll_skid_id  
   		WHERE "LINE_CURRENT_STATUS"."LINE_NUM" = :ii_line_id   
           ;
		case 15
			  UPDATE "LINE_CURRENT_STATUS"  
     		SET "SHEET_SKID_LOCATION_15" = :ll_skid_id  
   		WHERE "LINE_CURRENT_STATUS"."LINE_NUM" = :ii_line_id   
           ;
		case 16
			  UPDATE "LINE_CURRENT_STATUS"  
     		SET "SHEET_SKID_LOCATION_16" = :ll_skid_id  
   		WHERE "LINE_CURRENT_STATUS"."LINE_NUM" = :ii_line_id   
           ;
		case 17
			  UPDATE "LINE_CURRENT_STATUS"  
     		SET "SHEET_SKID_LOCATION_17" = :ll_skid_id  
   		WHERE "LINE_CURRENT_STATUS"."LINE_NUM" = :ii_line_id   
           ;
		case 18
			UPDATE "LINE_CURRENT_STATUS"  
     		SET "SHEET_SKID_LOCATION_18" = :ll_skid_id  
   		WHERE "LINE_CURRENT_STATUS"."LINE_NUM" = :ii_line_id   
           ;
		end choose
		if sqlca.sqlcode <> 0 then
			sqlca.of_rollback( )
			return -1
		end if
	next
	
	sqlca.of_commit( )
//	event ue_refresh_display_insert_delete( )

return 0
end function

public subroutine wf_opc_weight_ack ();if not ib_wt_ack then
//	ole_1.object.items(is_idleconveyor1weightack ).value = true
	ole_1.object.items(is_scaleremoteack ).value = true
	ole_1.object.update
		ib_wt_ack = true
	if not isValid( itmg_1_second_wt_ack )	then
		itmg_1_second_wt_ack = create n_tmg
		itmg_1_second_wt_ack.of_setsingle( true)
	end if
	itmg_1_second_wt_ack.inv_single.of_register( this, "ue_weight_ack", 1)
end if
//sleep(1)
//ole_1.object.items(is_idleconveyor1weightack ).value = false
//ole_1.object.update
//
end subroutine

public subroutine wf_print_skid_ticket (long al_skid_num, long al_job, long al_net, long al_tare);String lstr_customer_name, lstr_end_user ,lstr_alloy, lstr_temper,lstr_sheet_type, ls_shift
double ld_gauge, ld_length, ld_width
long ll_order_num, ll_shift
int li_order_item_num, li_skid_seq
DateTime ldt_t
Datastore lds_skid
		lds_skid = create datastore
		lds_skid.dataobject = "d_skid_ticket_new"
		lds_skid.settransobject( sqlca)
		lds_skid.retrieve( al_skid_num)
		
	ldt_t = DateTime(Today(),Now())	
		
  SELECT "CUSTOMER_A"."CUSTOMER_SHORT_NAME", "CUSTOMER_B"."CUSTOMER_SHORT_NAME", "ORDER_ITEM"."ALLOY2","ORDER_ITEM"."TEMPER","ORDER_ITEM"."GAUGE","ORDER_ITEM"."SHEET_TYPE","AB_JOB"."ORDER_ITEM_NUM","AB_JOB"."ORDER_ABC_NUM" 
    INTO :lstr_customer_name  , :lstr_end_user,:lstr_alloy, :lstr_temper, :ld_gauge, :lstr_sheet_type, :li_order_item_num, :ll_order_num
    FROM "AB_JOB",   
         "CUSTOMER" "CUSTOMER_A",
			"CUSTOMER" "CUSTOMER_B",
         "CUSTOMER_ORDER",   
         "ORDER_ITEM"  
   WHERE ( "ORDER_ITEM"."ORDER_ABC_NUM" = "CUSTOMER_ORDER"."ORDER_ABC_NUM" ) and  
         ( "ORDER_ITEM"."ORDER_ITEM_NUM" = "AB_JOB"."ORDER_ITEM_NUM" ) and  
         ( "ORDER_ITEM"."ORDER_ABC_NUM" = "AB_JOB"."ORDER_ABC_NUM" ) and
			( "CUSTOMER_A"."CUSTOMER_ID" = "CUSTOMER_ORDER"."ORIG_CUSTOMER_ID" ) and  
         ( "CUSTOMER_B"."CUSTOMER_ID" = "CUSTOMER_ORDER"."ENDUSER_ID" ) and
			( "AB_JOB"."AB_JOB_NUM" = :al_job )   ;
		
		choose case UPPER(trim(lstr_sheet_type))
//	case "CHEVRON"
//		SELECT "CHEVRON"."CH_LENGTH",
//         	"CHEVRON"."CH_WIDTH",
//    	INTO :ld_length,
//         	:ld_width
//    	FROM "CHEVRON"  
//   	WHERE ( "CHEVRON"."ORDER_ITEM_NUM" = :li_order_item_num ) AND  
//         ( "CHEVRON"."ORDER_ABC_NUM" = :ll_order_num ) 
//			;
	case "CIRCLE"
		SELECT "CIRCLE"."C_DIAMETER",   
         "CIRCLE"."C_DIAMETER"
    	INTO :ld_length,
         	:ld_width
    	FROM "CIRCLE"  
   	WHERE ( "CIRCLE"."ORDER_ITEM_NUM" = :li_order_item_num ) AND  
         ( "CIRCLE"."ORDER_ABC_NUM" = :ll_order_num )   
           ;
	case "FENDER"
			SELECT "FENDER"."FE_LENGTH", 
        			 "FENDER"."FE_SIDE"
    	INTO :ld_length,
         	:ld_width
    		FROM "FENDER"  
   		WHERE ( "FENDER"."ORDER_ITEM_NUM" = :li_order_item_num ) AND  
         	( "FENDER"."ORDER_ABC_NUM" = :ll_order_num ) ;
	
	case "LIFTGATE"
		SELECT "LIFTGATE_SHAPE"."LI_LENGTH",
         	"LIFTGATE_SHAPE"."LI_WIDTH"
    	INTO :ld_length,
         	:ld_width
    		FROM "LIFTGATE_SHAPE"  
   		WHERE ( "LIFTGATE_SHAPE"."ORDER_ITEM_NUM" = :li_order_item_num ) AND  
         	( "LIFTGATE_SHAPE"."ORDER_ABC_NUM" = :ll_order_num ) ;
	case "OTHER"
		SELECT "X1_SHAPE"."X_2",   
         "X1_SHAPE"."X_1"  
    		INTO :ld_length,   
         	:ld_width  
    		FROM "X1_SHAPE"  
   		WHERE ( "X1_SHAPE"."ORDER_ITEM_NUM" = :li_order_item_num ) AND  
         	( "X1_SHAPE"."ORDER_ABC_NUM" = :ll_order_num );
	case "PARALLELOGRAM"
		SELECT "PARALLELOGRAM"."P_LENGTH",
         	"PARALLELOGRAM"."P_WIDTH"
    	INTO :ld_length,
         	:ld_width
    		FROM "PARALLELOGRAM"  
   		WHERE ( "PARALLELOGRAM"."ORDER_ITEM_NUM" = :li_order_item_num ) AND  
         	( "PARALLELOGRAM"."ORDER_ABC_NUM" = :ll_order_num ) ;
	case "RECTANGLE"
		SELECT "RECTANGLE"."RT_LENGTH",
         	"RECTANGLE"."RT_WIDTH"
    	INTO :ld_length,
         	:ld_width
    		FROM "RECTANGLE"  
   		WHERE ( "RECTANGLE"."ORDER_ITEM_NUM" = :li_order_item_num ) AND  
         	( "RECTANGLE"."ORDER_ABC_NUM" = :ll_order_num ) ;
//	case "REINFORCEMENT"
//		SELECT "REINFORCEMENT"."RE_LENGTH",
//        		 "REINFORCEMENT"."RE_WIDTH",
//    	INTO :ld_length,
//         	:ld_width
//    		FROM "REINFORCEMENT"  
//   		WHERE ( "REINFORCEMENT"."ORDER_ITEM_NUM" = :li_order_item_num ) AND  
//         	( "REINFORCEMENT"."ORDER_ABC_NUM" = :ll_order_num ) ;
//	case "TRAPEZOID"
//		SELECT "TRAPEZOID"."TR_LONG_LENGTH",
//         	"TRAPEZOID"."TR_WIDTH",
//    	INTO :ld_length,
//         	:ld_width
//    		FROM "TRAPEZOID"  
//   		WHERE ( "TRAPEZOID"."ORDER_ITEM_NUM" = :li_order_item_num ) AND  
//         	( "TRAPEZOID"."ORDER_ABC_NUM" = :ll_order_num ) ;
	case "X SHAPE"
		SELECT "X1_SHAPE"."X_2",   
         "X1_SHAPE"."X_1"  
    		INTO :ld_length,   
         	:ld_width  
    		FROM "X1_SHAPE"  
   		WHERE ( "X1_SHAPE"."ORDER_ITEM_NUM" = :li_order_item_num ) AND  
         	( "X1_SHAPE"."ORDER_ABC_NUM" = :ll_order_num ) ;
	case else
		//
end choose

		SELECT  "SHIFT"."SCHEDULE_TYPE"
		INTO :ll_shift
		FROM "SHIFT","PRODUCTION_SHEET_ITEM"
		where ("SHIFT"."SHIFT_NUM" =  "PRODUCTION_SHEET_ITEM"."SHIFT_NUM") and
                              "PRODUCTION_SHEET_ITEM"."PROD_ITEM_DATE" = ( select MAX("PRODUCTION_SHEET_ITEM"."PROD_ITEM_DATE") 
                                                                                                         FROM "PRODUCTION_SHEET_ITEM",  "SHEET_SKID_DETAIL"  
                                                                                                          WHERE ( "SHEET_SKID_DETAIL"."SHEET_SKID_NUM" = :al_skid_num ) and  
                                              ( "SHEET_SKID_DETAIL"."PROD_ITEM_NUM" = "PRODUCTION_SHEET_ITEM"."PROD_ITEM_NUM" ) )
		USING SQLCA;

CHOOSE CASE ll_shift
               CASE 1
                              ls_shift = "1st Shift"
               CASE 2
                              ls_shift = "2nd Shift"
               CASE 3
                              ls_shift = "3rd Shift"
               CASE ELSE
                              ls_shift = " - "
END CHOOSE
			
		SELECT "SHEET_SKID"."SKID_SEQ_FOR_JOB" 
    		INTO :li_skid_seq  
    	FROM "SHEET_SKID"  
   WHERE "SHEET_SKID"."SHEET_SKID_NUM" = :al_skid_num;
	
			
			lds_skid.object.t_skid_seq.text = string(li_skid_seq)
		
		//Set Job and Coil info
		lds_skid.object.t_customer.text = lstr_customer_name
		lds_skid.object.t_enduser.text = "End User: " + lstr_end_user
		lds_skid.object.t_skid_num_b.text = "*S" + string(al_skid_num) + "*"
		lds_skid.object.t_skid_num_t.text = string(al_skid_num)
		lds_skid.object.t_job.text = string(al_job )
		lds_skid.object.t_alloy.text = lstr_alloy
		lds_skid.object.t_temper.text = lstr_temper
		lds_skid.object.t_gage.text = string(ld_gauge )
		lds_skid.object.t_width.text = string(ld_width )
		lds_skid.object.t_length.text = string(ld_length )
		lds_skid.object.t_gross_wt.text = string((al_net + al_tare))
		lds_skid.object.t_net.text = string(al_net)
		lds_skid.object.t_tare.text = string(al_tare)
		lds_skid.object.t_date.text = "Date: " + string(ldt_t, "MM/DD/YYYY")
		lds_skid.object.t_shift.text = ls_shift
		lds_skid.print( )
end subroutine

public function integer wf_unload_stack (integer ai_location);long ll_row, ll_job, ll_nw, ll_skid_id, ll_tare, ll_tare_wt

ll_row = wf_find_location_in_queue( ai_location)
	if ll_row > 0 then 
		ll_job = dw_stack_queue.object.ab_job_num[ll_row]
		ll_nw = dw_stack_queue.object.sheet_net_wt[ll_row]
		ll_skid_id = dw_stack_queue.object.sheet_skid_num[ll_row]
		  SELECT "AB_JOB"."JOB_TARE_WT"  
    		INTO :ll_tare  
    		FROM "AB_JOB"  
   		WHERE "AB_JOB"."AB_JOB_NUM" = :ll_job;
		
		if isNull(ll_tare ) or ll_tare < 0 then
			if not isValid( iw_tare ) then
				OpenWithParm(iw_tare, ll_job )
				ll_tare_wt = message.doubleparm
				if ll_tare_wt >= 0 then
					ll_tare = ll_tare_wt
					if messagebox("Question", "Do you want to save " + string(ll_tare) + " as default job tare weight?", Question!, YesNo! ) = 1 then
					  UPDATE "AB_JOB"  
     					SET "JOB_TARE_WT" = :ll_tare  
   					WHERE "AB_JOB"."AB_JOB_NUM" = :ll_job   
           			;
						if sqlca.sqlcode<>0 then
							messagebox("Error", "Error update tare on job table!")
							return 0
						else
							sqlca.of_commit( )
						end if
					end if
				else
//					messagebox("Invalid tare weight","Please enter valid tare weight!")
//					return 0
					ll_tare = 0
				end if
				//
			end if
		end if
		
		if ll_tare > 0 then
		  UPDATE "SHEET_SKID"  
     		SET "SHEET_TARE_WT" = :ll_tare  
   		WHERE "SHEET_SKID"."SHEET_SKID_NUM" = :ll_skid_id   
         ;
					if sqlca.sqlcode<>0 then
						messagebox("Error", "Error update tare on sheet_skid table!")
						return 0
					else
						sqlca.of_commit( )
					end if
		else
			ll_tare = 0
		end if

				
		wf_print_skid_ticket( ll_skid_id , ll_job , ll_nw , ll_tare )
		istr_last_skid.skid_id = ll_skid_id
		istr_last_skid.job_num = ll_job
		istr_last_skid.net_wt = ll_nw
		istr_last_skid.tare_wt = ll_tare
		
		dw_stack_queue.deleterow( ll_row )
		wf_update_line_current_status( )
		this.postevent( "ue_refresh_display_insert_delete")
		return 1
	end if
	return 0
end function

public subroutine of_queue_data_2_location (integer ai_loc);//
long ll_row

ll_row = wf_find_location_in_queue( ai_loc)
if ll_row > 0 then
	choose case ai_loc
		case 1
			dw_stack_queue.rowscopy( ll_row, ll_row, Primary!, dw_location_1 , 1, Primary!)
		case 0
			dw_stack_queue.rowscopy( ll_row, ll_row, Primary!, dw_location_0 , 1, Primary!)
		case 2
			dw_stack_queue.rowscopy( ll_row, ll_row, Primary!, dw_location_2 , 1, Primary!)
		case 3
			dw_stack_queue.rowscopy( ll_row, ll_row, Primary!, dw_location_3 , 1, Primary!)
		case 4
			dw_stack_queue.rowscopy( ll_row, ll_row, Primary!, dw_location_4 , 1, Primary!)
		case 5
			dw_stack_queue.rowscopy( ll_row, ll_row, Primary!, dw_location_5 , 1, Primary!)
		case 6
			dw_stack_queue.rowscopy( ll_row, ll_row, Primary!, dw_location_6 , 1, Primary!)
		case 7
			dw_stack_queue.rowscopy( ll_row, ll_row, Primary!, dw_location_7 , 1, Primary!)
		case 8
			dw_stack_queue.rowscopy( ll_row, ll_row, Primary!, dw_location_8 , 1, Primary!)
		case 9
			dw_stack_queue.rowscopy( ll_row, ll_row, Primary!, dw_location_9 , 1, Primary!)
		case 10
			dw_stack_queue.rowscopy( ll_row, ll_row, Primary!, dw_location_10 , 1, Primary!)
		case 11
			dw_stack_queue.rowscopy( ll_row, ll_row, Primary!, dw_location_11 , 1, Primary!)
		case 12
			dw_stack_queue.rowscopy( ll_row, ll_row, Primary!, dw_location_12 , 1, Primary!)
		case 13
			dw_stack_queue.rowscopy( ll_row, ll_row, Primary!, dw_location_13 , 1, Primary!)
		case 14
			dw_stack_queue.rowscopy( ll_row, ll_row, Primary!, dw_location_14 , 1, Primary!)
		case 15
			dw_stack_queue.rowscopy( ll_row, ll_row, Primary!, dw_location_15 , 1, Primary!)
		case 16
			dw_stack_queue.rowscopy( ll_row, ll_row, Primary!, dw_location_16 , 1, Primary!)
		case 17
			dw_stack_queue.rowscopy( ll_row, ll_row, Primary!, dw_location_17 , 1, Primary!)
		case 18
			dw_stack_queue.rowscopy( ll_row, ll_row, Primary!, dw_location_18 , 1, Primary!)
		case else
			/*statementblock*/
	end choose
end if
end subroutine

public subroutine of_read_scale ();/* Argument:
	COM1: 1
	COM2: 2
	COM3: 3
	COM4: 4
	COM5: 5
			...
*/
Long ll_rc
String ls_put, ls_get
Int li_com_port

ls_put = "HELLO"
ls_get = "1234567890123456789012345678901234567890123456789012345678901234567890123456789012345678901234567890"
li_com_port = ii_com_port -1 

string(SioKeycode(WSC_KEY_CODE))
ll_rc = SioReset( li_com_port,512, 512)
	if ll_rc < 0 then
		SioWinError(ls_get,128)
		MessageBox("System error", "Can not open serial port! " + ls_get)
//		return -1
	end if
	SioParms(li_com_port, WSC_NoParity, WSC_OneStopBit, WSC_WordLength8)
	SioBaud( li_com_port,WSC_Baud9600)
//String ls_put
ls_put = Char(5)
Char lc_test = Char(5) //ENQ
SioPutc( li_com_port, lc_test)// ENQ has 5 in Ascii table

//sleep(1) //wait for data coming back


//SioGets( li_com_port,ls_get, 128)
//ls_get = Upper(Trim(ls_get))
//
//int li_pos
//li_pos = Pos(ls_get,"L")
//ls_get = Trim(Left(ls_get, li_pos -1))
//
//if isNumber(ls_get)  then
//	ll_rc = Long( ls_get )
//else
//	ll_rc = 0
//end if
//
//SioDone(li_com_port)
////return ll_rc

end subroutine

public function long of_get_scale_wt ();Long ll_rc
String ls_put, ls_get
Int li_com_port

ls_put = "HELLO"
ls_get = "1234567890123456789012345678901234567890123456789012345678901234567890123456789012345678901234567890"
li_com_port = ii_com_port - 1
SioGets( li_com_port,ls_get, 128)
//MessageBox("back", ls_get)
ls_get = Upper(Trim(ls_get))
//ls_get = Trim(Mid(ls_get, 3, 9)) //Trim non numaric char

int li_pos
li_pos = Pos(ls_get,"L")
ls_get = Trim(Left(ls_get, li_pos -1))

if isNumber(ls_get)  then
	ll_rc = Long( ls_get )
else
	ll_rc = 0
end if

SioDone(li_com_port)
return ll_rc

end function

