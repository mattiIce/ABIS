event clicked;call super::clicked;
if dw_location_12.visible or dw_location_11.visible then
	MessageBox( "Can not move stack", "Please clear wrapper 1 skid!!" )
	return
end if
	ole_1.object.items(is_hmi_pbs_endwrap1).value = true
	ole_1.object.update
