event ue_refresh_display();int li_rc, li_i, li_j,li_conveyor, li_row
//st_time.text = string(Now())


li_rc = dw_stack_queue.rowcount( )

if li_rc < 1 then 
	dw_location_0.visible = false
	dw_location_1.visible = false
	dw_location_2.visible = false
	dw_location_3.visible = false
	dw_location_4.visible = false
	dw_location_5.visible = false
	dw_location_6.visible = false
	dw_location_7.visible = false
	dw_location_8.visible = false
	dw_location_9.visible = false
	dw_location_10.visible = false
	dw_location_11.visible = false
	dw_location_12.visible = false
	dw_location_13.visible = false
	dw_location_14.visible = false
	dw_location_15.visible = false
	dw_location_16.visible = false
	dw_location_17.visible = false
	dw_location_18.visible = false
	return
end if

for li_i=0 to 18
	li_row = dw_stack_queue.find( "location_code=" + string(li_i), 1, li_rc)
	if li_row > 0 then
		choose case li_i
		case 0
			if not dw_location_0.visible then
				dw_location_0.visible = true
				dw_stack_queue.rowscopy( li_row, li_row,Primary! , dw_location_0, 1, Primary!)
//				dw_location_0.scrolltorow( li_row )
			end if
		case 1
			if not dw_location_1.visible then
				dw_location_1.visible = true
				dw_stack_queue.rowscopy( li_row, li_row,Primary! , dw_location_1, 1, Primary!)

//				dw_location_1.scrolltorow( li_row )
//				dw_conveyor_1.setrow( li_row)
//				cb_scale.enabled = true
//				cb_wt_ack.enabled = true
			end if
		case 2
			if not dw_location_2.visible then
				dw_location_2.visible = true
				dw_stack_queue.rowscopy( li_row, li_row,Primary! , dw_location_2, 1, Primary!)
//				dw_location_2.scrolltorow( li_row )
			end if
		case 3
			if not dw_location_3.visible then
				dw_location_3.visible = true
				dw_stack_queue.rowscopy( li_row, li_row,Primary! , dw_location_3, 1, Primary!)
//				dw_location_3.scrolltorow( li_row )
			end if
		case 4
			if not dw_location_4.visible then
				dw_location_4.visible = true
				dw_stack_queue.rowscopy( li_row, li_row,Primary! , dw_location_4, 1, Primary!)
//				dw_location_4.scrolltorow( li_row )
			end if
		case 5
			if not dw_location_5.visible then
				dw_location_5.visible = true
				dw_stack_queue.rowscopy( li_row, li_row,Primary! , dw_location_5, 1, Primary!)
//				dw_location_5.scrolltorow( li_row )
			end if
		case 6
			if not dw_location_6.visible then
				dw_location_6.visible = true
				dw_stack_queue.rowscopy( li_row, li_row,Primary! , dw_location_6, 1, Primary!)
//				dw_location_6.scrolltorow( li_row )
			end if
		case 7
			if not dw_location_7.visible then
				dw_location_7.visible = true
				dw_stack_queue.rowscopy( li_row, li_row,Primary! , dw_location_7, 1, Primary!)
//				dw_location_7.scrolltorow( li_row )
			end if
		case 8
			if not dw_location_8.visible then
				dw_location_8.visible = true
				dw_stack_queue.rowscopy( li_row, li_row,Primary! , dw_location_8, 1, Primary!)
//				dw_location_8.scrolltorow( li_row )
			end if
		case 9
			if not dw_location_9.visible then
				dw_location_9.visible = true
				dw_stack_queue.rowscopy( li_row, li_row,Primary! , dw_location_9, 1, Primary!)
//				dw_location_9.scrolltorow( li_row )
			end if
		case 10
			if not dw_location_10.visible then
				dw_location_10.visible = true
				dw_stack_queue.rowscopy( li_row, li_row,Primary! , dw_location_10, 1, Primary!)
//				dw_location_10.scrolltorow( li_row )
			end if
		case 11
			if not dw_location_11.visible then
				dw_location_11.visible = true
				dw_stack_queue.rowscopy( li_row, li_row,Primary! , dw_location_11, 1, Primary!)
//				dw_location_11.scrolltorow( li_row )
			end if
		case 12
			if not dw_location_12.visible then
				dw_location_12.visible = true
				dw_stack_queue.rowscopy( li_row, li_row,Primary! , dw_location_12, 1, Primary!)
//				dw_location_12.scrolltorow( li_row )
			end if
		case 13
			if not dw_location_13.visible then
				dw_location_13.visible = true
				dw_stack_queue.rowscopy( li_row, li_row,Primary! , dw_location_13, 1, Primary!)
//				dw_location_13.scrolltorow( li_row )
			end if
		case 14
			if not dw_location_14.visible then
				dw_location_14.visible = true
				dw_stack_queue.rowscopy( li_row, li_row,Primary! , dw_location_14, 1, Primary!)
//				dw_location_14.scrolltorow( li_row )
				
			end if
		case 15
			if not dw_location_15.visible then
				dw_location_15.visible = true
				dw_stack_queue.rowscopy( li_row, li_row,Primary! , dw_location_15, 1, Primary!)
//				dw_location_15.scrolltorow( li_row )
			end if
		case 16
			if not dw_location_16.visible then
				dw_location_16.visible = true
				dw_stack_queue.rowscopy( li_row, li_row,Primary! , dw_location_16, 1, Primary!)
//				dw_location_16.scrolltorow( li_row )
			end if
		case 17
			if not dw_location_17.visible then
				dw_location_17.visible = true
				dw_stack_queue.rowscopy( li_row, li_row,Primary! , dw_location_17, 1, Primary!)
//				dw_location_17.scrolltorow( li_row )
			end if
		case 18
			if not dw_location_18.visible then
				dw_location_18.visible = true
				dw_stack_queue.rowscopy( li_row, li_row,Primary! , dw_location_18, 1, Primary!)
//				dw_location_18.scrolltorow( li_row )
			end if
		end choose	
	else
		choose case li_i
		case 0
				if dw_location_0.visible then dw_location_0.visible = false
		case 1
				if dw_location_1.visible then dw_location_1.visible = false
		case 2
				if dw_location_2.visible then dw_location_2.visible = false

//				if dw_conveyor_2.visible then 
//					dw_conveyor_2.visible = false
////					cb_scale.enabled = false
////					cb_wt_ack.enabled = false
//				end if
		case 3
					if dw_location_3.visible then dw_location_3.visible = false
		case 4
				if dw_location_4.visible then dw_location_4.visible = false
		case 5
				if dw_location_5.visible then dw_location_5.visible = false
		case 6
				if dw_location_6.visible then dw_location_6.visible = false
		case 7
				if dw_location_7.visible then dw_location_7.visible = false
		case 8
				if dw_location_8.visible then dw_location_8.visible = false
		case 9
				if dw_location_9.visible then dw_location_9.visible = false
		case 10
				if dw_location_10.visible then dw_location_10.visible = false
		case 11
				if dw_location_11.visible then dw_location_11.visible = false
		case 12
				if dw_location_12.visible then dw_location_12.visible = false
		case 13
				if dw_location_13.visible then dw_location_13.visible = false
		case 14
				if dw_location_14.visible then dw_location_14.visible = false
		case 15
				if dw_location_15.visible then dw_location_15.visible = false
		case 16
				if dw_location_16.visible then dw_location_16.visible = false
		case 17
				if dw_location_17.visible then dw_location_17.visible = false
		case 18
				if dw_location_18.visible then dw_location_18.visible = false
		end choose	
	end if
next

end event

event ue_sta1_complete();//
return
long ll_skid_id, ll_job,ll_nw,ll_row, ll_coil
int li_seq_job

li_seq_job = 0

ll_row = wf_find_location_in_queue( 0 )

  SELECT "LINE_CURRENT_STATUS"."SHEET_SKID_STACKER_1", "LINE_CURRENT_STATUS"."COIL_ABC_NUM"
    INTO :ll_skid_id , :ll_coil 
    FROM "LINE_CURRENT_STATUS"  
   WHERE "LINE_CURRENT_STATUS"."LINE_NUM" = :ii_line_id ;
	
	if isNull(ll_skid_id) or ll_skid_id < 1000 then return
	
	if ll_row > 0 then
		if dw_stack_queue.object.sheet_skid_num[ll_row] = ll_skid_id and dw_stack_queue.object.stacker[ll_row]  = 1 then return
	end if

	if dw_stack_queue.find( "sheet_skid_num=" + string(ll_skid_id), 1, dw_stack_queue.rowcount( ) ) > 0 then return
	
	
	
	  SELECT //"SHEET_SKID"."SHEET_SKID_NUM",   
         "SHEET_SKID"."AB_JOB_NUM",   
         "SHEET_SKID"."SHEET_NET_WT",   
         "SHEET_SKID"."SKID_SEQ_FOR_JOB"  
    INTO //:skid_id,   
         :ll_job ,   
         :ll_nw ,   
         :li_seq_job  
    FROM "SHEET_SKID"  
   WHERE "SHEET_SKID"."SHEET_SKID_NUM" = :ll_skid_id   
           ;
	
		
	if isNull(li_seq_job) or li_seq_job = 0 then
		SELECT COUNT(*)
		INTO :li_seq_job
		FROM SHEET_SKID
		WHERE AB_JOB_NUM = :ll_job;
	end if
	
	ll_row = dw_stack_queue.insertrow( 0 )
	
	
	dw_stack_queue.object.sheet_skid_num[ll_row] = ll_skid_id
	dw_stack_queue.object.ab_job_num[ll_row] = ll_job
	dw_stack_queue.object.skid_seq_for_job[ll_row] = li_seq_job
	dw_stack_queue.object.sheet_net_wt[ll_row] = ll_nw
	dw_stack_queue.object.location_code[ll_row] = 0
	dw_stack_queue.object.conveyor[ll_row] = 0
	dw_stack_queue.object.stacker[ll_row] = 1
	dw_stack_queue.object.coil_abc_num[ll_row] = ll_coil
	UPDATE "LINE_CURRENT_STATUS"
	SET "SHEET_SKID_STACKER_1" = NULL
	WHERE "LINE_CURRENT_STATUS"."LINE_NUM" = :ii_line_id ;
	
	event ue_refresh_display_insert_delete( )
	wf_update_line_current_status()
end event

