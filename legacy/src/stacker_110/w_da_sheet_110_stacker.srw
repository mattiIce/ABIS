event ue_stack_unloaded_from_wp2_unload_conv();int li_rc
li_rc = wf_find_location_in_queue( 18 )
if li_rc > 0 then
	//cb_unload_skid.event clicked( )
//-----------------------------------------------------------------------

	long ll_row, ll_job, ll_nw, ll_skid_id, ll_tare, ll_tare_wt

ll_row = li_rc
	if ll_row > 0 then 
		ll_job = dw_stack_queue.object.ab_job_num[ll_row]
		ll_nw = dw_stack_queue.object.sheet_net_wt[ll_row]
		ll_skid_id = dw_stack_queue.object.sheet_skid_num[ll_row]
		  SELECT "AB_JOB"."JOB_TARE_WT"  
    		INTO :ll_tare  
    		FROM "AB_JOB"  
   		WHERE "AB_JOB"."AB_JOB_NUM" = :ll_job;
		
		if isNull(ll_tare ) or ll_tare < 0 then
			ll_tare = 0
//			if not isValid( iw_tare ) then
//				OpenWithParm(iw_tare, ll_job )
//				ll_tare_wt = message.doubleparm
//				if ll_tare_wt >= 0 then
//					ll_tare = ll_tare_wt
//					if messagebox("Question", "Do you want to save " + string(ll_tare) + " as default job tare weight?", Question!, YesNo! ) = 1 then
//					  UPDATE "AB_JOB"  
//     					SET "JOB_TARE_WT" = :ll_tare  
//   					WHERE "AB_JOB"."AB_JOB_NUM" = :ll_job   
//           			;
//						if sqlca.sqlcode<>0 then
//							messagebox("Error", "Error update tare on job table!")
//							return 0
//						else
//							sqlca.of_commit( )
//						end if
//					end if
//				else
//					messagebox("Invalid tare weight","Please enter valid tare weight!")
//					return 0
//				end if
				//
//			end if
		end if
	
	if ll_tare > 0 then
	
		  UPDATE "SHEET_SKID"  
     		SET "SHEET_TARE_WT" = :ll_tare  
   		WHERE "SHEET_SKID"."SHEET_SKID_NUM" = :ll_skid_id   
         ;
					if sqlca.sqlcode<>0 then
						messagebox("Error", "Error update tare on sheet_skid table!")
						return
					else
						sqlca.of_commit( )
					end if
		end if
				
		wf_print_skid_ticket( ll_skid_id , ll_job , ll_nw , ll_tare )
		istr_last_skid.skid_id = ll_skid_id
		istr_last_skid.job_num = ll_job
		istr_last_skid.net_wt = ll_nw
		istr_last_skid.tare_wt = ll_tare
		
		dw_stack_queue.deleterow( ll_row )
		wf_update_line_current_status( )
		this.postevent( "ue_refresh_display_insert_delete")
//		return 1
	end if
//	return 0













