event ue_refresh_display_insert_delete();int li_rc, li_i, li_j,li_conveyor, li_row
//st_time.text = string(Now())

li_rc = dw_stack_queue.rowcount( )

if li_rc < 1 then 
//	dw_conveyor_0.visible = false
//	dw_conveyor_1.visible = false
//	dw_conveyor_2.visible = false
//	dw_conveyor_3.visible = false
//	dw_wraper_1_unload.visible = false
//	dw_wraper_2_load.visible = false
//	dw_wraper_2_unload.visible = false
//	dw_overhead_crane.visible = false
	tab_tracking.tabpage_real_time.dw_location_0.visible = false
	tab_tracking.tabpage_real_time.dw_location_1.visible = false
	tab_tracking.tabpage_real_time.dw_location_2.visible = false
	tab_tracking.tabpage_real_time.dw_location_3.visible = false
	tab_tracking.tabpage_real_time.dw_location_4.visible = false
	tab_tracking.tabpage_real_time.dw_location_5.visible = false
	tab_tracking.tabpage_real_time.dw_location_6.visible = false
	tab_tracking.tabpage_real_time.dw_location_7.visible = false
