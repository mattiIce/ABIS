		case 10
				if tab_tracking.tabpage_real_time.dw_location_10.visible then tab_tracking.tabpage_real_time.dw_location_10.visible = false
		case 11
				if tab_tracking.tabpage_real_time.dw_location_11.visible then tab_tracking.tabpage_real_time.dw_location_11.visible = false
		case 12
				if tab_tracking.tabpage_real_time.dw_location_12.visible then tab_tracking.tabpage_real_time.dw_location_12.visible = false
		case 13
				if tab_tracking.tabpage_real_time.dw_location_13.visible then tab_tracking.tabpage_real_time.dw_location_13.visible = false
		case 14
				if tab_tracking.tabpage_real_time.dw_location_14.visible then tab_tracking.tabpage_real_time.dw_location_14.visible = false
		case 15
				if tab_tracking.tabpage_real_time.dw_location_15.visible then tab_tracking.tabpage_real_time.dw_location_15.visible = false
		case 16
