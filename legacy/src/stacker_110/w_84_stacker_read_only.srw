event ue_stack_unloaded_from_wp2_unload_conv();int li_rc
li_rc = wf_find_location_in_queue( 18 )
if li_rc > 0 then
	dw_stack_queue.deleterow( li_rc )
	//Other unload handling
else
//	mle_log.text = mle_log.text + "~r~nStack unloaded from wp1 unload conv can not find previous location!"
end if
