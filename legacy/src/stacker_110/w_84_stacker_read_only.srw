				tab_tracking.tabpage_real_time.dw_location_18.visible = true
				tab_tracking.tabpage_real_time.dw_location_18.scrolltorow( li_row )
			end if
		end choose	
	else
		choose case li_i
		case 0
				if tab_tracking.tabpage_real_time.dw_location_0.visible then tab_tracking.tabpage_real_time.dw_location_0.visible = false
		case 1
				if tab_tracking.tabpage_real_time.dw_location_1.visible then tab_tracking.tabpage_real_time.dw_location_1.visible = false
		case 2
				if tab_tracking.tabpage_real_time.dw_location_2.visible then tab_tracking.tabpage_real_time.dw_location_2.visible = false

//				if dw_conveyor_2.visible then 
//					dw_conveyor_2.visible = false
////					cb_scale.enabled = false
////					cb_wt_ack.enabled = false
//				end if
		case 3
					if tab_tracking.tabpage_real_time.dw_location_3.visible then tab_tracking.tabpage_real_time.dw_location_3.visible = false
	case 4
				if tab_tracking.tabpage_real_time.dw_location_4.visible then tab_tracking.tabpage_real_time.dw_location_4.visible = false
		case 5
				if tab_tracking.tabpage_real_time.dw_location_5.visible then tab_tracking.tabpage_real_time.dw_location_5.visible = false
		case 6
				if tab_tracking.tabpage_real_time.dw_location_6.visible then tab_tracking.tabpage_real_time.dw_location_6.visible = false
		case 7
				if tab_tracking.tabpage_real_time.dw_location_7.visible then tab_tracking.tabpage_real_time.dw_location_7.visible = false
		case 8
