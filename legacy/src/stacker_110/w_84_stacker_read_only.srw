on w_84_stacker_read_only.create
int iCurrent
call super::create
this.dw_dt_gr_t_back=create dw_dt_gr_t_back
this.dw_dt_summary_t_back=create dw_dt_summary_t_back
this.dw_dt_log_t_back=create dw_dt_log_t_back
this.cb_error=create cb_error
this.cb_refresh=create cb_refresh
this.cb_exit=create cb_exit
this.dw_stack_queue=create dw_stack_queue
this.st_title=create st_title
this.tab_tracking=create tab_tracking
iCurrent=UpperBound(this.Control)
this.Control[iCurrent+1]=this.dw_dt_gr_t_back
this.Control[iCurrent+2]=this.dw_dt_summary_t_back
this.Control[iCurrent+3]=this.dw_dt_log_t_back
this.Control[iCurrent+4]=this.cb_error
this.Control[iCurrent+5]=this.cb_refresh
this.Control[iCurrent+6]=this.cb_exit
this.Control[iCurrent+7]=this.dw_stack_queue
this.Control[iCurrent+8]=this.st_title
this.Control[iCurrent+9]=this.tab_tracking
end on

on w_84_stacker_read_only.destroy
call super::destroy
destroy(this.dw_dt_gr_t_back)
destroy(this.dw_dt_summary_t_back)
destroy(this.dw_dt_log_t_back)
destroy(this.cb_error)
destroy(this.cb_refresh)
destroy(this.cb_exit)
destroy(this.dw_stack_queue)
destroy(this.st_title)
destroy(this.tab_tracking)
end on

event pfc_postopen;call super::pfc_postopen;string ls_devicename, ls_line
int li_line_width
long ll_value, ll_shift
Real lr_feedlength, lr_rejectlength
//If not isValid(iw_please_wait) then
//	open(iw_please_wait, this)
//end if

dw_dt_log_t_back.Visible = FALSE
dw_dt_summary_t_back.Visible = FALSE
dw_dt_gr_t_back.Visible = FALSE

ls_line = ProfileString(gs_downtime_ini_file,"DataBase","LogId84","bl84")
li_line_width = integer(mid(ls_line,3))
sqlca.of_connect( )	 	
		SELECT "LINE"."LINE_NUM"  
    		INTO :ii_line_id  
    	FROM "LINE"  
   	WHERE "LINE"."MAX_WIDTH" = :li_line_width;
if sqlca.sqlcode <> 0 then
//	uo_sql.set_select( false)
	MessageBox("Database", "Error finding line id!")
else
//	uo_sql.set_select( true)
end if

//itmg_every_second = create n_tmg
//itmg_every_second.of_setsingle( true)
//itmg_every_second.inv_single.of_register( this, "ue_every_second", 1)

itmg_every_2_seconds = create n_tmg
itmg_every_2_seconds.of_setsingle( true)
itmg_every_2_seconds.inv_single.of_register( this, "ue_every_2_seconds", 2)

itmg_every_minute = create n_tmg
itmg_every_minute.of_setsingle( true)
itmg_every_minute.inv_single.of_register( this, "ue_every_minute", 60)


//st_msg.text = "Connection on line"
wf_init_stack_queue( )
dw_stack_queue.sharedata( tab_tracking.tabpage_real_time.dw_location_0 )
dw_stack_queue.sharedata( tab_tracking.tabpage_real_time.dw_location_1 )
dw_stack_queue.sharedata( tab_tracking.tabpage_real_time.dw_location_2 )
dw_stack_queue.sharedata( tab_tracking.tabpage_real_time.dw_location_3 )
dw_stack_queue.sharedata( tab_tracking.tabpage_real_time.dw_location_4 )
dw_stack_queue.sharedata( tab_tracking.tabpage_real_time.dw_location_5 )
dw_stack_queue.sharedata( tab_tracking.tabpage_real_time.dw_location_6 )
dw_stack_queue.sharedata( tab_tracking.tabpage_real_time.dw_location_7 )
dw_stack_queue.sharedata( tab_tracking.tabpage_real_time.dw_location_8 )
dw_stack_queue.sharedata( tab_tracking.tabpage_real_time.dw_location_9 )
dw_stack_queue.sharedata( tab_tracking.tabpage_real_time.dw_location_10 )
