//--------------Video handling-----------------------
is_media_type = "mjpeg"
is_media_url = "http://" + "192.168.10.130" + "/axis-cgi/mjpg/video.cgi"


ib_autostart = true
tab_tracking.tabpage_real_time.ole_video.object.MediaType = is_media_type
tab_tracking.tabpage_real_time.ole_video.object.MediaURL = is_media_url
tab_tracking.tabpage_real_time.ole_video.object.StretchToFit = true
tab_tracking.tabpage_real_time.ole_video.object.MaintainAspectRatio = false
tab_tracking.tabpage_real_time.ole_video.object.FullScreen = false
tab_tracking.tabpage_real_time.ole_video.object.play
tab_tracking.tabpage_real_time.cb_play.enabled = false


//--------------End of Video-------------------------
ib_post_open = true

//dw_dt_log_t_back.ShareData(tab_tracking.tabpage_real_time.dw_dt_log_t)
//dw_dt_summary_t_back.ShareData(tab_tracking.tabpage_real_time.dw_dt_summary_t)
//dw_dt_gr_t_back.ShareData(tab_tracking.tabpage_real_time.dw_dt_gr_t)

this.Event ue_show_shift_info_on_realtime()


end event

