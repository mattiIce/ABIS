	tab_tracking.tabpage_real_time.dw_location_13.visible = false
	tab_tracking.tabpage_real_time.dw_location_14.visible = false
	tab_tracking.tabpage_real_time.dw_location_15.visible = false
	tab_tracking.tabpage_real_time.dw_location_16.visible = false
	tab_tracking.tabpage_real_time.dw_location_17.visible = false
	tab_tracking.tabpage_real_time.dw_location_18.visible = false
	return
end if

