# ABIS API deployment config. Copy to `.env` and fill in. DO NOT commit `.env`.

# Host port to publish the API/UI on (container always listens on 8080 internally).
ABIS_PORT=8080

# Oracle connection string for the plant DB (use a non-prod copy first).
# SID form (matches the recovered schema):
ABIS_DB_CONNECTION=Data Source=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=db-host)(PORT=1521))(CONNECT_DATA=(SID=abc11)));User Id=APP_USER;Password=CHANGE_ME;

# API key that clients must send as the X-Api-Key header. Use a long random value.
ABIS_API_KEY=change-me-to-a-strong-random-key

# Optional user sign-in (OIDC). Leave blank to keep API-key-only auth. When set,
# the API validates JWT bearer tokens AND the web screens show a Sign-in button.
# Register the SPA client with each /ui/*.html as a redirect URI in your provider.
ABIS_OIDC_AUTHORITY=
ABIS_OIDC_AUDIENCE=
ABIS_OIDC_CLIENT_ID=
ABIS_OIDC_SCOPE=openid profile
